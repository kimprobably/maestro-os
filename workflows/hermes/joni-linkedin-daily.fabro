digraph JoniLinkedInDaily {
    graph [
        goal="Select a private LinkedIn feed cohort from Joni's SQLite watchlist, capture approved signals with HarvestAPI, score post performance deterministically, then run a bounded AI review for patterns and draft ideas",
        persona="joni",
        inputs="feed_db,capture_mode,posted_limit,max_pages,source_limit,tier_a_percent,rotation_limit,candidate_limit",
        outputs="selected_sources,normalized_posts,daily_summary,feed_candidates,ai_review,ledger_entry",
        default_max_retries=1,
        retry_target="capture_linkedin_posts",
        fallback_retry_target="summarize_capture",
        model_stylesheet="
            *       { provider: openai; model: gpt-5.4-mini; reasoning_effort: low; }
            .coding { provider: openai; model: gpt-5.4-mini; reasoning_effort: medium; }
            .review { provider: openai; model: gpt-5.4; reasoning_effort: medium; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    ensure_feed_watchlist [
        label="Ensure Feed Watchlist DB",
        shape=parallelogram,
        goal_gate=true,
        retry_target="ensure_feed_watchlist",
        script="mkdir -p .workflow/joni-linkedin/daily; node scripts/hermes/joni-feed-watchlist.mjs init --db '{{ inputs.feed_db|default('/data/.hermes/profiles/joni/state/linkedin-feed/joni-linkedin-feed.sqlite') }}'"
    ]

    select_daily_sources [
        label="Select Daily Feed Sources",
        shape=parallelogram,
        goal_gate=true,
        retry_target="select_daily_sources",
        script="node scripts/hermes/joni-feed-watchlist.mjs select-sources --db '{{ inputs.feed_db|default('/data/.hermes/profiles/joni/state/linkedin-feed/joni-linkedin-feed.sqlite') }}' --out .workflow/joni-linkedin/daily/selected-sources.json --limit '{{ inputs.source_limit|default('300') }}' --tier-a-percent '{{ inputs.tier_a_percent|default('20') }}' --rotation-limit '{{ inputs.rotation_limit|default('45') }}'"
    ]

    validate_harvest_sources [
        label="Validate HarvestAPI Sources",
        shape=parallelogram,
        goal_gate=true,
        retry_target="validate_harvest_sources",
        script="node scripts/hermes/joni-linkedin-capture.mjs validate --sources .workflow/joni-linkedin/daily/selected-sources.json --out-dir .workflow/joni-linkedin/daily --mode '{{ inputs.capture_mode|default('live') }}'"
    ]

    capture_linkedin_posts [
        label="Capture LinkedIn Posts",
        shape=parallelogram,
        goal_gate=true,
        retry_target="capture_linkedin_posts",
        script="node scripts/hermes/joni-linkedin-capture.mjs capture --sources .workflow/joni-linkedin/daily/selected-sources.json --out-dir .workflow/joni-linkedin/daily --mode '{{ inputs.capture_mode|default('live') }}' --posted-limit '{{ inputs.posted_limit|default('24h') }}' --max-pages '{{ inputs.max_pages|default('1') }}'"
    ]

    summarize_capture [
        label="Deterministic Capture Summary",
        shape=parallelogram,
        goal_gate=true,
        retry_target="capture_linkedin_posts",
        script="test -f .workflow/joni-linkedin/daily/posts.jsonl; test -f .workflow/joni-linkedin/daily/summary.json; test -f .workflow/joni-linkedin/daily/summary.md; echo capture-summary-ready"
    ]

    record_feed_snapshots [
        label="Record Feed Snapshots",
        shape=parallelogram,
        goal_gate=true,
        retry_target="record_feed_snapshots",
        script="node scripts/hermes/joni-feed-watchlist.mjs record-posts --db '{{ inputs.feed_db|default('/data/.hermes/profiles/joni/state/linkedin-feed/joni-linkedin-feed.sqlite') }}' --posts .workflow/joni-linkedin/daily/posts.jsonl"
    ]

    score_feed_candidates [
        label="Score Feed Candidates",
        shape=parallelogram,
        goal_gate=true,
        retry_target="score_feed_candidates",
        script="node scripts/hermes/joni-feed-watchlist.mjs score --db '{{ inputs.feed_db|default('/data/.hermes/profiles/joni/state/linkedin-feed/joni-linkedin-feed.sqlite') }}' --out-dir .workflow/joni-linkedin/daily --limit '{{ inputs.candidate_limit|default('25') }}' --since-days '{{ inputs.since_days|default('30') }}'"
    ]

    ai_pattern_review [
        label="AI Pattern Review",
        class="review",
        goal_gate=true,
        retry_target="score_feed_candidates",
        prompt="@../../prompts/hermes/joni-linkedin-ai-review.md"
    ]

    verify_ai_review [
        label="Verify AI Review",
        shape=parallelogram,
        goal_gate=true,
        retry_target="ai_pattern_review",
        script="node scripts/hermes/joni-linkedin-capture.mjs verify-review --out-dir .workflow/joni-linkedin/daily"
    ]

    append_linkedin_ledger [
        label="Append LinkedIn Ledger",
        shape=parallelogram,
        goal_gate=true,
        retry_target="verify_ai_review",
        script="node scripts/hermes/joni-linkedin-capture.mjs ledger --out-dir .workflow/joni-linkedin/daily --ledger docs/operator/linkedin/JONI-LINKEDIN-LEDGER.md && node scripts/hermes/joni-feed-watchlist.mjs ledger --db '{{ inputs.feed_db|default('/data/.hermes/profiles/joni/state/linkedin-feed/joni-linkedin-feed.sqlite') }}' --out-dir .workflow/joni-linkedin/daily --ledger docs/operator/linkedin/JONI-LINKEDIN-LEDGER.md"
    ]

    start -> ensure_feed_watchlist
    ensure_feed_watchlist -> select_daily_sources [condition="outcome=succeeded"]
    ensure_feed_watchlist -> ensure_feed_watchlist [label="Fix DB", loop_restart=true, max_visits=2]
    select_daily_sources -> validate_harvest_sources [condition="outcome=succeeded"]
    select_daily_sources -> select_daily_sources [label="Fix Selection", loop_restart=true, max_visits=2]
    validate_harvest_sources -> capture_linkedin_posts [condition="outcome=succeeded"]
    validate_harvest_sources -> select_daily_sources [label="Fix Sources", loop_restart=true, max_visits=2]
    capture_linkedin_posts -> summarize_capture [condition="outcome=succeeded"]
    capture_linkedin_posts -> validate_harvest_sources [label="Fix Capture Input"]
    summarize_capture -> record_feed_snapshots [condition="outcome=succeeded"]
    summarize_capture -> capture_linkedin_posts [label="Fix Summary"]
    record_feed_snapshots -> score_feed_candidates [condition="outcome=succeeded"]
    record_feed_snapshots -> summarize_capture [label="Fix Snapshots"]
    score_feed_candidates -> ai_pattern_review [condition="outcome=succeeded"]
    score_feed_candidates -> record_feed_snapshots [label="Fix Scores"]
    ai_pattern_review -> verify_ai_review [condition="outcome=succeeded"]
    ai_pattern_review -> ai_pattern_review [label="Fix Review", loop_restart=true, max_visits=2]
    verify_ai_review -> append_linkedin_ledger [condition="outcome=succeeded"]
    verify_ai_review -> ai_pattern_review [label="Fix Review"]
    append_linkedin_ledger -> exit [condition="outcome=succeeded"]
    append_linkedin_ledger -> verify_ai_review [label="Fix Ledger"]
}
