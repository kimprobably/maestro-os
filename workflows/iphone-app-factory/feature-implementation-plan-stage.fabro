digraph FeatureImplementationPlanStage {
    graph [
        goal="Map an approved feature spec onto exact existing-app code, tests, screenshots, and CI evidence",
        persona="existing-app-feature-implementation-planner",
        inputs="app_dir,required_capabilities",
        outputs="contract.artifact,contract.gate,contract.next_action,contract.failure_classification,implementation_plan",
        secret_policy="no secrets; do not print environment variables or credential values",
        model_stylesheet="* { backend: cli; provider: openai; model: gpt-5.3-codex; reasoning_effort: high; }"
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    write_implementation_plan [
        label="Write Implementation Plan",
        shape=parallelogram,
        retry_target="write_implementation_plan",
        timeout="3600s",
        script="node scripts/iphone-app-factory/run-codex-prompt.mjs --prompt prompts/iphone-app-factory/feature-implementation-plan.md --stage feature-implementation-plan --eval-id iphone-feature.implementation-plan.call --out .workflow/existing-app-feature/codex/feature-implementation-plan.json"
    ]
    validate_implementation_plan [
        label="Validate Implementation Plan",
        shape=parallelogram,
        retry_target="write_implementation_plan",
        script="node scripts/iphone-app-factory/feature-implementation-plan-gate.mjs"
    ]

    start -> write_implementation_plan
    write_implementation_plan -> validate_implementation_plan [condition="outcome=succeeded"]
    write_implementation_plan -> write_implementation_plan [label="Rewrite Implementation Plan"]
    validate_implementation_plan -> exit [condition="outcome=succeeded"]
    validate_implementation_plan -> write_implementation_plan [label="Fix Implementation Plan"]
}
