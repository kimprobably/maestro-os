digraph BuildIPhoneApp {
    graph [
        goal="Build a differentiated iPhone app from a researched app opportunity using SwiftAIBoilerplatePro",
        persona="iphone-app-factory",
        secret_policy="never print environment variables or credential values; credential checks must be presence-only true/false checks; do not run environment dump commands.",
        inputs="app_type,target_audience,app_name,bundle_id,app_dir,spec_kitty_feature,boilerplate_repo,max_competitors,use_mobbin,ios_validation_mode,allow_macos_deferred",
        outputs="research_pack,spec,architecture,swift_app,ios_quality_report,appium_report,release_handoff",
        default_max_retries=2,
        retry_target="spec_consensus",
        fallback_retry_target="architecture_consensus",
        model_stylesheet="
            *                  { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: low; max_tokens: 2048; }
            .research          { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: high; max_tokens: 4096; }
            .design            { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: high; max_tokens: 4096; }
            .spec              { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 4096; }
            .architecture      { provider: openrouter; model: qwen/qwen3.6-plus; reasoning_effort: high; max_tokens: 4096; }
            .coding            { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 4096; }
            .review            { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 2048; }
            .verify            { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: medium; max_tokens: 1024; }
            .security          { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 2048; }
            .simplify          { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 4096; }
            .macos             { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 4096; }
            #spec_codex        { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; max_tokens: 4096; }
            #spec_claude       { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: high; max_tokens: 4096; }
            #spec_kimi         { provider: openrouter; model: google/gemini-3.1-flash-lite; reasoning_effort: high; max_tokens: 4096; }
            #spec_deepseek     { provider: openrouter; model: deepseek/deepseek-v4-pro; reasoning_effort: high; max_tokens: 4096; }
            #arch_codex        { provider: openrouter; model: qwen/qwen3.6-plus; reasoning_effort: high; max_tokens: 4096; }
            #arch_claude       { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: high; max_tokens: 4096; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    bootstrap [
        label="Bootstrap iPhone Factory",
        shape=parallelogram,
        goal_gate=true,
        retry_target="bootstrap",
        script="node scripts/iphone-app-factory/bootstrap.mjs --app-dir '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --app-name '{{ inputs.app_name|default('Generated iPhone App') }}' --bundle-id '{{ inputs.bundle_id|default('com.maestro.generatediphoneapp') }}' --boilerplate-repo '{{ inputs.boilerplate_repo|default('SwiftAIBoilerplatePro/SwiftAIBoilerplatePro-Distribution') }}'"
    ]
    run_input_gate [
        label="Run Input Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="run_input_gate",
        script="node scripts/iphone-app-factory/run-input-gate.mjs --app-type '{{ inputs.app_type|default('') }}' --target-audience '{{ inputs.target_audience|default('') }}' --app-name '{{ inputs.app_name|default('Generated iPhone App') }}' --bundle-id '{{ inputs.bundle_id|default('com.maestro.generatediphoneapp') }}' --app-dir '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --spec-kitty-feature '{{ inputs.spec_kitty_feature|default('iphone-app-factory') }}' --ios-validation-mode '{{ inputs.ios_validation_mode|default('github') }}' --allow-macos-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]

    prompt_quality_gate [
        label="Prompt Quality Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="prompt_quality_gate",
        script="node scripts/iphone-app-factory/promptfoo-prompt-quality.mjs --config evals/iphone-app-factory/prompt-quality.yaml --registry evals/iphone-app-factory/prompt-registry.json --out .workflow/iphone-app-factory/evals/prompt-quality.json --allow-fallback true --accepted-risk-promptfoo-failure false"
    ]

    research_fanout [label="Research Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    app_store_research [label="App Store Reviews", class="research", max_tokens=4096, prompt="@../../prompts/iphone-app-factory/research-app-store.md"]
    reddit_research [label="Reddit Pain Mining", class="research", max_tokens=4096, prompt="@../../prompts/iphone-app-factory/research-reddit.md"]
    competitor_research [label="Competitor Research", class="research", max_tokens=4096, prompt="@../../prompts/iphone-app-factory/research-competitors.md"]
    design_pattern_research [label="Design Pattern Research", class="design", max_tokens=4096, prompt="@../../prompts/iphone-app-factory/research-design-patterns.md"]
    research_join [label="Research Join", shape=tripleoctagon, join_policy="wait_all"]

    research_synthesis [
        label="Research Synthesis",
        class="research",
        max_tokens=4096,
        goal_gate=true,
        retry_target="research_fanout",
        prompt="@../../prompts/iphone-app-factory/synthesize-research.md"
    ]
    research_evidence_gate [
        label="Research Evidence Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="research_fanout",
        script="node scripts/iphone-app-factory/research-evidence-gate.mjs"
    ]

    spec_fanout [label="Adversarial Spec Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    spec_codex [label="Gemini Spec", class="spec", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_claude [label="Claude Spec", class="spec", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_kimi [label="Gemini Flash Spec", class="spec", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_deepseek [label="DeepSeek Spec", class="spec", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_join [label="Spec Join", shape=tripleoctagon, join_policy="wait_all"]

    spec_cross_critique [
        label="Spec Cross-Critique",
        class="review",
        max_tokens=2048,
        goal_gate=true,
        retry_target="spec_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/spec-cross-critique.md"
    ]
    spec_consensus [
        label="Spec Consensus",
        class="spec",
        max_tokens=4096,
        goal_gate=true,
        retry_target="spec_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/spec-consensus.md"
    ]
    spec_red_team [
        label="Spec Red Team",
        class="review",
        max_tokens=2048,
        goal_gate=true,
        retry_target="spec_consensus",
        prompt="@../../prompts/iphone-app-factory/spec-red-team.md"
    ]
    spec_quality_gate [
        label="Spec Quality Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="spec_consensus",
        script="node scripts/iphone-app-factory/spec-gate.mjs"
    ]
    spec_kitty_gate [
        label="Spec Kitty Mission",
        shape=parallelogram,
        goal_gate=true,
        retry_target="spec_consensus",
        script="FEATURE='{{ inputs.spec_kitty_feature|default('iphone-app-factory') }}'; if command -v spec-kitty >/dev/null 2>&1; then spec-kitty specify \"$FEATURE\" --mission-type software-dev --json > .workflow/iphone-app-factory/spec-kitty.json || spec-kitty verify-setup --json > .workflow/iphone-app-factory/spec-kitty.json; else echo 'spec-kitty is required for this workflow' >&2; exit 1; fi; cat .workflow/iphone-app-factory/spec-kitty.json"
    ]

    architecture_fanout [label="Architecture Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    arch_codex [label="Qwen Architecture", class="architecture", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/architecture-candidate.md"]
    arch_claude [label="Claude Architecture", class="architecture", max_tokens=4096, fidelity="truncate", prompt="@../../prompts/iphone-app-factory/architecture-candidate.md"]
    architecture_join [label="Architecture Join", shape=tripleoctagon, join_policy="wait_all"]
    architecture_consensus [
        label="Architecture And ADR",
        class="architecture",
        max_tokens=4096,
        goal_gate=true,
        retry_target="architecture_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/architecture-consensus.md"
    ]
    architecture_gate [
        label="Architecture Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="architecture_consensus",
        script="test -s .workflow/iphone-app-factory/architecture.md; test -s .workflow/iphone-app-factory/adr.md; grep -Eq 'SwiftAIBoilerplatePro|boilerplate|Packages/|DesignSystem|CompositionRoot' .workflow/iphone-app-factory/architecture.md"
    ]

    boilerplate_setup [
        label="Clone And Rebrand Boilerplate",
        class="coding",
        max_tokens=4096,
        goal_gate=true,
        retry_target="boilerplate_setup",
        prompt="@../../prompts/iphone-app-factory/boilerplate-setup.md"
    ]
    boilerplate_gate [
        label="Boilerplate Contract Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="boilerplate_setup",
        script="node scripts/iphone-app-factory/boilerplate-contract-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]

    implement_foundation [label="Implement Foundation", class="coding", max_tokens=4096, goal_gate=true, retry_target="implement_foundation", prompt="@../../prompts/iphone-app-factory/implement-foundation.md"]
    verify_foundation [label="Verify Foundation", class="verify", max_tokens=1024, goal_gate=true, retry_target="implement_foundation", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_foundation [label="Foundation Gate", shape=parallelogram, goal_gate=true, retry_target="implement_foundation", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs foundation '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_core [label="Implement Core", class="coding", max_tokens=4096, goal_gate=true, retry_target="implement_core", prompt="@../../prompts/iphone-app-factory/implement-core.md"]
    verify_core [label="Verify Core", class="verify", max_tokens=1024, goal_gate=true, retry_target="implement_core", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_core [label="Core Gate", shape=parallelogram, goal_gate=true, retry_target="implement_core", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs core '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_interface [label="Implement Interface", class="coding", max_tokens=4096, goal_gate=true, retry_target="implement_interface", prompt="@../../prompts/iphone-app-factory/implement-interface.md"]
    verify_interface [label="Verify Interface", class="verify", max_tokens=1024, goal_gate=true, retry_target="implement_interface", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_interface [label="Interface Gate", shape=parallelogram, goal_gate=true, retry_target="implement_interface", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs interface '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_integration [label="Implement Integration", class="coding", max_tokens=4096, goal_gate=true, retry_target="implement_integration", prompt="@../../prompts/iphone-app-factory/implement-integration.md"]
    verify_integration [label="Verify Integration", class="verify", max_tokens=1024, goal_gate=true, retry_target="implement_integration", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_integration [label="Integration Gate", shape=parallelogram, goal_gate=true, retry_target="implement_integration", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs integration '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implementation_review_fanout [label="Implementation Review Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    implementation_correctness_review [label="Implementation Correctness", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-implementation-correctness.md"]
    implementation_test_review [label="Implementation Tests", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-implementation-tests.md"]
    implementation_security_review [label="Implementation Security", class="security", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-implementation-security.md"]
    implementation_boilerplate_review [label="Implementation Boilerplate", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-implementation-boilerplate.md"]
    implementation_review_join [label="Implementation Review Join", shape=tripleoctagon, join_policy="wait_all"]
    implementation_review_fan_in_gate [
        label="Implementation Review Fan-In Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implementation_review_fanout",
        script="node scripts/iphone-app-factory/review-fan-in-gate.mjs --mode implementation --reviews-dir .workflow/iphone-app-factory/reviews"
    ]
    implementation_review_consensus [
        label="Implementation Review Consensus",
        class="review",
        max_tokens=2048,
        goal_gate=true,
        retry_target="implement_integration",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/review-implementation-consensus.md"
    ]
    implementation_review_gate [
        label="Implementation Review Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implement_integration",
        script="./bin/maestro verify text-gate .workflow/iphone-app-factory/reviews/implementation-consensus.md --pass 'VERDICT:\\s*APPROVED' --fail 'VERDICT:\\s*REJECTED|\\bREJECTED\\b'"
    ]
    prompt_context_budget_gate [
        label="Prompt Context Budget Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implementation_review_consensus",
        script="node scripts/iphone-app-factory/prompt-context-budget-gate.mjs --root .workflow/iphone-app-factory"
    ]

    simplification [
        label="Code Simplification",
        class="simplify",
        max_tokens=4096,
        goal_gate=true,
        retry_target="simplification",
        prompt="@../../prompts/iphone-app-factory/simplification.md"
    ]
    quality_contract_gate [
        label="Quality Harness Contract",
        shape=parallelogram,
        goal_gate=true,
        retry_target="simplification",
        script="node scripts/iphone-app-factory/quality-contract-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    macos_ci_gate [
        label="macOS iOS CI Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implement_integration",
        timeout="3600s",
        script="node scripts/iphone-app-factory/ios-ci-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --mode '{{ inputs.ios_validation_mode|default('github') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]
    ai_ui_explorer [
        label="AI UI Explorer",
        class="macos",
        max_tokens=4096,
        goal_gate=true,
        retry_target="implement_interface",
        prompt="@../../prompts/iphone-app-factory/ai-ui-explorer.md"
    ]
    appium_gate [
        label="Appium Exploratory Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="ai_ui_explorer",
        script="node scripts/iphone-app-factory/appium-report-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]
    app_store_hardening [
        label="App Store 4.3 Hardening",
        class="review",
        max_tokens=2048,
        goal_gate=true,
        retry_target="implement_interface",
        prompt="@../../prompts/iphone-app-factory/app-store-hardening.md"
    ]
    app_store_gate [
        label="App Store Hardening Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="app_store_hardening",
        script="node scripts/iphone-app-factory/app-store-hardening-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]

    final_review_fanout [label="Final Review Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    product_fidelity_review [label="Product Fidelity", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-product-fidelity.md"]
    ios_architecture_review [label="iOS Architecture", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-ios-architecture.md"]
    security_privacy_review [label="Security Privacy", class="security", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-security-privacy.md"]
    code_quality_review [label="Code Quality", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-code-quality.md"]
    release_readiness_review [label="Release Readiness", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-release-readiness.md"]
    qa_review [label="QA Evidence", class="review", max_tokens=2048, prompt="@../../prompts/iphone-app-factory/review-qa-evidence.md"]
    final_review_join [label="Final Review Join", shape=tripleoctagon, join_policy="wait_all"]
    final_review_fan_in_gate [
        label="Final Review Fan-In Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_review_fanout",
        script="node scripts/iphone-app-factory/review-fan-in-gate.mjs --mode final --reviews-dir .workflow/iphone-app-factory/reviews"
    ]
    final_prompt_context_budget_gate [
        label="Final Prompt Context Budget Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_review_fanout",
        script="node scripts/iphone-app-factory/prompt-context-budget-gate.mjs --root .workflow/iphone-app-factory"
    ]
    final_consensus [
        label="Final Consensus",
        class="review",
        max_tokens=2048,
        goal_gate=true,
        retry_target="simplification",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/final-consensus.md"
    ]
    final_gate [
        label="Final Verdict Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="simplification",
        script="./bin/maestro verify text-gate .workflow/iphone-app-factory/final-consensus.md --pass 'VERDICT:\\s*APPROVED' --fail 'VERDICT:\\s*REJECTED|\\bREJECTED\\b'"
    ]
    publish_handoff [
        label="Publish Handoff",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_consensus",
        script="node scripts/iphone-app-factory/publish-handoff.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    artifact_metadata_gate [
        label="Artifact Metadata Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="publish_handoff",
        script="node scripts/iphone-app-factory/artifact-metadata-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    memory_summary [
        label="Memory Summary",
        shape=parallelogram,
        script="printf '{\"kind\":\"iphone_app_factory.completed\",\"payload\":{\"app_dir\":\"{{ inputs.app_dir|default('apps/generated-iphone-app') }}\",\"app_name\":\"{{ inputs.app_name|default('Generated iPhone App') }}\"}}' | ./bin/maestro memory append 'team/iphone-app-factory/builds' >/dev/null; echo memory-updated"
    ]

    start -> run_input_gate
    run_input_gate -> bootstrap [condition="outcome=succeeded"]
    run_input_gate -> run_input_gate [label="Fix Inputs", loop_restart=true]
    bootstrap -> prompt_quality_gate [condition="outcome=succeeded"]
    bootstrap -> bootstrap [label="Retry", loop_restart=true]
    prompt_quality_gate -> research_fanout [condition="outcome=succeeded"]
    prompt_quality_gate -> prompt_quality_gate [label="Retry", loop_restart=true]
    research_fanout -> app_store_research
    research_fanout -> reddit_research
    research_fanout -> competitor_research
    research_fanout -> design_pattern_research
    app_store_research -> research_join
    reddit_research -> research_join
    competitor_research -> research_join
    design_pattern_research -> research_join
    research_join -> research_synthesis
    research_synthesis -> research_evidence_gate [condition="outcome=succeeded"]
    research_synthesis -> research_fanout [label="Retry"]
    research_evidence_gate -> spec_fanout [condition="outcome=succeeded"]
    research_evidence_gate -> research_fanout [label="Retry"]

    spec_fanout -> spec_codex
    spec_fanout -> spec_claude
    spec_fanout -> spec_kimi
    spec_fanout -> spec_deepseek
    spec_codex -> spec_join
    spec_claude -> spec_join
    spec_kimi -> spec_join
    spec_deepseek -> spec_join
    spec_join -> spec_cross_critique
    spec_cross_critique -> spec_consensus [condition="outcome=succeeded"]
    spec_cross_critique -> spec_fanout [label="Retry"]
    spec_consensus -> spec_red_team [condition="outcome=succeeded"]
    spec_consensus -> spec_fanout [label="Retry"]
    spec_red_team -> spec_quality_gate [condition="outcome=succeeded"]
    spec_red_team -> spec_consensus [label="Fix"]
    spec_quality_gate -> spec_kitty_gate [condition="outcome=succeeded"]
    spec_quality_gate -> spec_consensus [label="Fix"]
    spec_kitty_gate -> architecture_fanout [condition="outcome=succeeded"]
    spec_kitty_gate -> spec_consensus [label="Fix"]

    architecture_fanout -> arch_codex
    architecture_fanout -> arch_claude
    arch_codex -> architecture_join
    arch_claude -> architecture_join
    architecture_join -> architecture_consensus
    architecture_consensus -> architecture_gate [condition="outcome=succeeded"]
    architecture_consensus -> architecture_fanout [label="Retry"]
    architecture_gate -> boilerplate_setup [condition="outcome=succeeded"]
    architecture_gate -> architecture_consensus [label="Fix"]

    boilerplate_setup -> boilerplate_gate [condition="outcome=succeeded"]
    boilerplate_setup -> boilerplate_setup [label="Retry", loop_restart=true]
    boilerplate_gate -> implement_foundation [condition="outcome=succeeded"]
    boilerplate_gate -> boilerplate_setup [label="Fix"]

    implement_foundation -> verify_foundation [condition="outcome=succeeded"]
    implement_foundation -> implement_foundation [label="Retry", loop_restart=true]
    verify_foundation -> gate_foundation [condition="outcome=succeeded"]
    verify_foundation -> implement_foundation [label="Fix"]
    gate_foundation -> implement_core [condition="outcome=succeeded"]
    gate_foundation -> implement_foundation [label="Fix"]

    implement_core -> verify_core [condition="outcome=succeeded"]
    implement_core -> implement_core [label="Retry", loop_restart=true]
    verify_core -> gate_core [condition="outcome=succeeded"]
    verify_core -> implement_core [label="Fix"]
    gate_core -> implement_interface [condition="outcome=succeeded"]
    gate_core -> implement_core [label="Fix"]

    implement_interface -> verify_interface [condition="outcome=succeeded"]
    implement_interface -> implement_interface [label="Retry", loop_restart=true]
    verify_interface -> gate_interface [condition="outcome=succeeded"]
    verify_interface -> implement_interface [label="Fix"]
    gate_interface -> implement_integration [condition="outcome=succeeded"]
    gate_interface -> implement_interface [label="Fix"]

    implement_integration -> verify_integration [condition="outcome=succeeded"]
    implement_integration -> implement_integration [label="Retry", loop_restart=true]
    verify_integration -> gate_integration [condition="outcome=succeeded"]
    verify_integration -> implement_integration [label="Fix"]
    gate_integration -> implementation_review_fanout [condition="outcome=succeeded"]
    gate_integration -> implement_integration [label="Fix"]

    implementation_review_fanout -> implementation_correctness_review
    implementation_review_fanout -> implementation_test_review
    implementation_review_fanout -> implementation_security_review
    implementation_review_fanout -> implementation_boilerplate_review
    implementation_correctness_review -> implementation_review_join
