digraph QualityStackSmoke {
    graph [
        goal="Verify the local Maestro quality stack through one doctor command",
        persona="quality-smoke",
        inputs="",
        outputs="quality_stack_report",
        default_max_retries=1,
        retry_target="doctor_quality_stack",
        fallback_retry_target="doctor_quality_stack",
        model_stylesheet="
            *       { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: low; }
            .coding { provider: openrouter; model: qwen/qwen3.6-plus; reasoning_effort: high; }
            .review { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    doctor_quality_stack [
        label="Doctor Quality Stack",
        shape=parallelogram,
        goal_gate=true,
        retry_target="doctor_quality_stack",
        script="mkdir -p .workflow; ./bin/maestro doctor quality-stack > .workflow/quality-stack-doctor.json; node -e \"const fs=require('fs'); const report=JSON.parse(fs.readFileSync('.workflow/quality-stack-doctor.json','utf8')); if (report.ok !== true) throw new Error('quality stack failed'); if (report.data.failed !== 0) throw new Error('failed_count ' + report.data.failed); const ids=new Set(report.data.checks.map((check)=>check.id)); for (const id of ['fabro_server','fabro_github','openrouter_models','qlty','spec_kitty','daytona_cli','github_cli_auth','linear_api']) { if (!ids.has(id)) throw new Error('missing check ' + id); } console.log(JSON.stringify({passed: report.data.passed, failed: report.data.failed, warnings: report.data.warnings}));\""
    ]

    write_report [
        label="Write Quality Stack Report",
        shape=parallelogram,
        goal_gate=true,
        retry_target="doctor_quality_stack",
        script="node -e \"const fs=require('fs'); const report=JSON.parse(fs.readFileSync('.workflow/quality-stack-doctor.json','utf8')); const lines=['# Quality Stack Smoke', '', 'passed=' + report.data.passed, 'failed=' + report.data.failed, 'warnings=' + report.data.warnings, '', ...report.data.checks.map((check)=>'- ' + check.id + '=' + check.status + ' ' + (check.detail || ''))]; fs.writeFileSync('.workflow/quality-stack-smoke.md', lines.join('\\n') + '\\n'); console.log(lines.join('\\n'));\""
    ]

    start -> doctor_quality_stack
    doctor_quality_stack -> write_report [condition="outcome=succeeded"]
    doctor_quality_stack -> doctor_quality_stack [label="Retry", loop_restart=true, max_visits=2]
    write_report -> exit [condition="outcome=succeeded"]
    write_report -> doctor_quality_stack [label="Repair", loop_restart=true]
}
