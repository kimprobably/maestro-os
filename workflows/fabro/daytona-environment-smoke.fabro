digraph DaytonaEnvironmentSmoke {
    graph [
        goal="Verify the shared Daytona code-factory environment boots with the expected tools",
        persona="workflow-registry",
        inputs="none",
        outputs="environment_report",
        model_stylesheet="
            *       { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: low; }
            .coding { provider: openrouter; model: qwen/qwen3.6-plus; reasoning_effort: medium; }
            .review { provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: medium; }
        "
    ]

    start [shape=Mdiamond, label="Start"]
    exit [shape=Msquare, label="Exit"]

    check_environment [
        label="Check Environment",
        type="command",
        script="mkdir -p .workflow/fabro; node -e \"const fs=require('fs'); const {spawnSync}=require('child_process'); const commandError=(r)=>r.error ? (r.error.code || 'command error') : r.signal ? 'signal ' + r.signal : r.status===null ? 'timeout' : r.status!==0 ? 'command failed' : null; const run=(cmd,args=[])=>{const r=spawnSync(cmd,args,{encoding:'utf8',timeout:45000}); const error=commandError(r); return {cmd:[cmd,...args].join(' '), status:r.status, output:error ? undefined : (r.stdout||r.stderr||'').trim().split('\\n')[0].slice(0,160), error};}; const networkStatus=(network)=>network.map((check)=>({url:check.url,status:check.status,...(check.error ? {error:check.error} : {})})); const networkError=(error)=>{const name=error && error.name ? error.name : ''; const message=String(error && error.message ? error.message : ''); if(name==='AbortError' || /abort/i.test(message)) return 'timeout or aborted'; if(/fetch failed/i.test(message)) return 'fetch failed'; return name || 'network error';}; const mcp=()=>{const r=spawnSync('claude',['mcp','list'],{encoding:'utf8',timeout:15000,stdio:['ignore','pipe','pipe']}); const text=((r.stdout||'')+'\\n'+(r.stderr||'')); const configured=/mobbin/i.test(text); const unauthorized=/(unauthori[sz]ed|not authorized|login required|oauth required|needs auth)/i.test(text); return {status:r.status, mobbin_mcp_configured:configured, mobbin_mcp_authorized:configured && !unauthorized};}; const probe=async(url)=>{const controller=new AbortController(); const timer=setTimeout(()=>controller.abort(),20000); try{const res=await fetch(url,{redirect:'manual',signal:controller.signal,headers:{'user-agent':'maestro-daytona-smoke/1.0'}}); return {url,status:res.status,ok:res.status>=200 && res.status<500};}catch(error){return {url,status:null,ok:false,error:networkError(error)};}finally{clearTimeout(timer);}}; (async()=>{const toolRuns=[run('node',['--version']),run('npm',['--version']),run('bun',['--version']),run('qlty',['--version']),run('spec-kitty',['--version']),run('promptfoo',['--version']),run('fabro',['--version']),run('claude',['--version']),run('codex',['--version'])]; const networkTargets=['https://api.github.com/rate_limit','https://apps.apple.com/','https://developer.apple.com/design/human-interface-guidelines/','https://mobbin.com/mcp','https://api.mobbin.com/mcp','https://pageflows.com/','https://www.reddit.com/']; const network=[]; for(const url of networkTargets) network.push(await probe(url)); const env=['OPENROUTER_API_KEY','DAYTONA_API_KEY','LINEAR_API_KEY','FABRO_SLACK_BOT_TOKEN','FABRO_SLACK_CHANNEL_ID','APIFY_TOKEN'].reduce((acc,key)=>{const value=process.env[key]||''; const unresolved=value.charCodeAt(0)===123 && value.charCodeAt(1)===123; acc[key]=Boolean(value && !unresolved); return acc;},{}); const required=['node --version','npm --version','bun --version','qlty --version','spec-kitty --version','promptfoo --version','fabro --version']; const failed=[...toolRuns.filter((check)=>required.includes(check.cmd) && check.status!==0).map((check)=>({cmd:check.cmd,status:check.status,error:check.error || 'command failed'})),...network.filter((check)=>!check.ok).map((check)=>({cmd:check.url,status:check.status,error:check.error || 'network check failed'}))]; const report={ok:failed.length===0, failed, checks:toolRuns, network, mobbin_mcp:mcp(), env}; fs.writeFileSync('.workflow/fabro/daytona-environment-smoke.json', JSON.stringify(report,null,2)+'\\n'); console.log(JSON.stringify({ok:report.ok,failed:report.failed,checks:report.checks,network:networkStatus(report.network),mobbin_mcp:report.mobbin_mcp,env:report.env},null,2)); if(!report.ok) process.exit(1);})().catch((error)=>{console.error('environment smoke failed'); process.exit(1);});\""
    ]

    write_report [
        label="Write Report",
        type="command",
        script="node -e \"const fs=require('fs'); const report=JSON.parse(fs.readFileSync('.workflow/fabro/daytona-environment-smoke.json','utf8')); const lines=['# Daytona Environment Smoke','', 'ok=' + report.ok, '', '## Tools', ...report.checks.map((check)=>'- ' + check.cmd + ' status=' + check.status + (check.error ? ' error=' + check.error : '') + (check.output ? ' output=' + check.output : '')), '', '## Network', ...report.network.map((check)=>'- ' + check.url + ' status=' + check.status + (check.error ? ' error=' + check.error : '')), '', '## Mobbin MCP', '- configured=' + report.mobbin_mcp.mobbin_mcp_configured, '- authorized=' + report.mobbin_mcp.mobbin_mcp_authorized, '', '## Env', ...Object.entries(report.env).map(([key,value])=>'- ' + key + '=' + value)]; fs.writeFileSync('.workflow/fabro/daytona-environment-smoke.md', lines.join('\\n')+'\\n'); console.log(lines.join('\\n')); if(!report.ok) process.exit(1);\""
    ]

    check_cli_auth_env [
        label="Check CLI Auth Env",
        type="command",
        script="node -e \"const fs=require('fs'); const keys=['OPENROUTER_API_KEY','OPENAI_API_KEY','CLAUDE_CODE_OAUTH_TOKEN','CLAUDE_CODE_CREDENTIALS_JSON_BASE64','CODEX_AUTH_JSON_BASE64']; const env=Object.fromEntries(keys.map((key)=>{const value=process.env[key]||''; const unresolved=value.includes('{{') || value.includes('}}'); return [key, Boolean(value && !unresolved)];})); const report={ok:true, env}; fs.writeFileSync('.workflow/fabro/daytona-cli-auth-env.json', JSON.stringify(report,null,2)+'\\n'); console.log(JSON.stringify(report,null,2));\""
    ]

    fail_environment [
        label="Fail Environment",
        type="command",
        script="node -e \"const fs=require('fs'); const path='.workflow/fabro/daytona-environment-smoke.json'; const report=fs.existsSync(path) ? JSON.parse(fs.readFileSync(path,'utf8')) : {}; const network=(report.network||[]).map((check)=>({url:check.url,status:check.status,...(check.error ? {error:check.error} : {})})); console.error(JSON.stringify({ok:report.ok,failed:report.failed||[],network},null,2)); process.exit(1);\""
    ]

    start -> check_environment
    check_environment -> check_cli_auth_env
    check_cli_auth_env -> write_report [condition="outcome=succeeded"]
    check_cli_auth_env -> fail_environment [label="Fail"]
    write_report -> exit [condition="outcome=succeeded"]
    write_report -> fail_environment [label="Fail"]
}
