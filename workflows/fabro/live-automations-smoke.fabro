digraph LiveAutomationsSmoke {
    graph [
        goal="Verify the live Fabro Automations API with a real Fabro run",
        persona="automation-smoke",
        inputs="",
        outputs="workflow_api_report",
        default_max_retries=1,
        retry_target="probe_api",
        fallback_retry_target="probe_api",
        model_stylesheet="
            *       { provider: openrouter; model: anthropic/claude-haiku-4-5; reasoning_effort: low; }
            .coding { backend: cli; provider: anthropic; model: claude-sonnet-4-5; reasoning_effort: high; }
            .review { backend: cli; provider: anthropic; model: claude-sonnet-4-5; reasoning_effort: high; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    probe_api [
        label="Probe Live Automations API",
        shape=parallelogram,
        goal_gate=true,
        retry_target="probe_api",
        script="mkdir -p .workflow; TOKEN=$(cat ~/.fabro/storage/server.dev-token); curl -fsS -H \"Authorization: Bearer $TOKEN\" http://127.0.0.1:32276/api/v1/workflows > .workflow/live-automations.json; node -e \"const fs=require('fs'); const body=JSON.parse(fs.readFileSync('.workflow/live-automations.json','utf8')); const data=body['data']; if (!Array.isArray(data)) throw new Error('workflow data is not an array'); if (data.length === 0) throw new Error('no live workflows returned'); if (!data.every((w)=>typeof w['name']==='string' && typeof w['slug']==='string' && typeof w['filename']==='string')) throw new Error('workflow item missing required strings'); const first=(data[0] && data[0]['slug']) || null; console.log(JSON.stringify({workflow_count: data.length, first_slug: first}));\""
    ]

    write_report [
        label="Write Smoke Report",
        shape=parallelogram,
        goal_gate=true,
        retry_target="probe_api",
        script="node -e \"const fs=require('fs'); const body=JSON.parse(fs.readFileSync('.workflow/live-automations.json','utf8')); const data=body['data']; const first=(data[0] && data[0]['slug']) || ''; const lines=['# Live Automations Smoke', '', 'workflow_count=' + data.length, 'first_slug=' + first]; fs.writeFileSync('.workflow/live-automations-smoke.md', lines.join('\\n') + '\\n'); console.log(lines.join('\\n'));\""
    ]

    start -> probe_api
    probe_api -> write_report [condition="outcome=succeeded"]
    probe_api -> probe_api   [label="Retry", loop_restart=true, max_visits=2]
    write_report -> exit      [condition="outcome=succeeded"]
    write_report -> probe_api [label="Repair", loop_restart=true]
}
