{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,420p' apps/waketask-ios/Packages/DesignSystem/Sources/DesignSystem/Components/WakeVisualComponents.swift\"","aggregated_output":"import SwiftUI\n\npublic struct WakeCard<Content: View>: View {\n    public enum Style {\n        case standard\n        case elevated\n        case tinted\n    }\n\n    private let style: Style\n    private let content: Content\n\n    public init(\n        style: Style = .standard,\n        @ViewBuilder content: () -> Content\n    ) {\n        self.style = style\n        self.content = content()\n    }\n\n    public var body: some View {\n        content\n            .padding(WakeSpacing.md)\n            .frame(maxWidth: .infinity, alignment: .leading)\n            .background(background)\n            .clipShape(RoundedRectangle(cornerRadius: DSRadius.md, style: .continuous))\n            .overlay(\n                RoundedRectangle(cornerRadius: DSRadius.md, style: .continuous)\n                    .stroke(WakeColorTokens.highContrastBorder.opacity(0.2), lineWidth: 1)\n            )\n    }\n\n    private var background: Color {\n        switch style {\n        case .standard: WakeColorTokens.surfaceCard\n        case .elevated: WakeColorTokens.surfaceCard\n        case .tinted: WakeColorTokens.actionSecondary\n        }\n    }\n}\n\npublic struct WakeRow: View {\n    private let title: String\n    private let subtitle: String?\n    private let chipText: String?\n    private let chipTone: WakeStateTone\n    private let icon: String?\n\n    public init(\n        title: String,\n        subtitle: String? = nil,\n        chipText: String? = nil,\n        chipTone: WakeStateTone = .active,\n        icon: String? = nil\n    ) {\n        self.title = title\n        self.subtitle = subtitle\n        self.chipText = chipText\n        self.chipTone = chipTone\n        self.icon = icon\n    }\n\n    public var body: some View {\n        HStack(alignment: .top, spacing: WakeSpacing.sm) {\n            if let icon {\n                Image(systemName: icon)\n                    .foregroundStyle(WakeColorTokens.textSecondary)\n                    .accessibilityHidden(true)\n            }\n\n            VStack(alignment: .leading, spacing: WakeSpacing.xxs) {\n                Text(title)\n                    .font(WakeTypography.bodyStrong)\n                    .foregroundStyle(WakeColorTokens.textPrimary)\n                    .fixedSize(horizontal: false, vertical: true)\n                if let subtitle {\n                    Text(subtitle)\n                        .font(WakeTypography.detail)\n                        .foregroundStyle(WakeColorTokens.textSecondary)\n                        .fixedSize(horizontal: false, vertical: true)\n                }\n            }\n            Spacer(minLength: WakeSpacing.xs)\n            if let chipText {\n                WakeStatusChip(text: chipText, tone: chipTone)\n            }\n        }\n        .frame(minHeight: 44)\n    }\n}\n\npublic struct WakeStatusChip: View {\n    let text: String\n    let tone: WakeStateTone\n\n    public init(text: String, tone: WakeStateTone) {\n        self.text = text\n        self.tone = tone\n    }\n\n    public var body: some View {\n        HStack(spacing: WakeSpacing.xxs) {\n            Image(systemName: tone.iconName)\n                .font(.caption2)\n                .accessibilityHidden(true)\n            Text(text)\n                .font(WakeTypography.status)\n                .lineLimit(1)\n                .minimumScaleFactor(0.85)\n        }\n        .foregroundStyle(tone.color)\n        .padding(.horizontal, WakeSpacing.xs)\n        .padding(.vertical, WakeSpacing.xxs)\n        .background(tone.color.opacity(0.13))\n        .clipShape(Capsule())\n        .accessibilityElement(children: .ignore)\n        .accessibilityLabel(Text(text))\n        .accessibilityAddTraits(.isStaticText)\n    }\n}\n\npublic struct WakeProgressStatus: View {\n    private let title: String\n    private let message: String\n    private let progress: Double\n    private let tone: WakeStateTone\n\n    public init(title: String, message: String, progress: Double, tone: WakeStateTone = .active) {\n        self.title = title\n        self.message = message\n        self.progress = progress\n        self.tone = tone\n    }\n\n    public var body: some View {\n        VStack(alignment: .leading, spacing: WakeSpacing.xs) {\n            Text(title)\n                .font(WakeTypography.title)\n            Text(message)\n                .font(WakeTypography.detail)\n                .foregroundStyle(WakeColorTokens.textSecondary)\n            ProgressView(value: min(max(progress, 0), 1))\n                .tint(tone.color)\n                .accessibilityValue(\"\\(Int(progress * 100))%\")\n        }\n        .accessibilityElement(children: .combine)\n    }\n}\n\npublic struct WakePrimaryActionButton: View {\n    private let title: String\n    private let role: ButtonRole?\n    private let action: () -> Void\n\n    public init(_ title: String, role: ButtonRole? = nil, action: @escaping () -> Void) {\n        self.title = title\n        self.role = role\n        self.action = action\n    }\n\n    public var body: some View {\n        Button(role: role) {\n            Haptics.tap()\n            action()\n        } label: {\n            Text(title)\n                .font(WakeTypography.bodyStrong)\n                .frame(maxWidth: .infinity)\n                .frame(minHeight: 44)\n        }\n        .buttonStyle(.borderedProminent)\n        .tint(role == .destructive ? WakeColorTokens.destructive : WakeColorTokens.actionPrimary)\n        .accessibilityAddTraits(.isButton)\n    }\n}\n\npublic struct WakeSecondaryActionButton: View {\n    private let title: String\n    private let action: () -> Void\n\n    public init(_ title: String, action: @escaping () -> Void) {\n        self.title = title\n        self.action = action\n    }\n\n    public var body: some View {\n        Button(action: action) {\n            Text(title)\n                .font(WakeTypography.body)\n                .frame(maxWidth: .infinity)\n                .frame(minHeight: 44)\n        }\n        .buttonStyle(.bordered)\n        .tint(WakeColorTokens.actionPrimary)\n    }\n}\n\npublic struct WakeEmptyStateView: View {\n    private let title: String\n    private let message: String\n    private let actionTitle: String\n    private let action: () -> Void\n\n    public init(title: String, message: String, actionTitle: String, action: @escaping () -> Void) {\n        self.title = title\n        self.message = message\n        self.actionTitle = actionTitle\n        self.action = action\n    }\n\n    public var body: some View {\n        WakeCard(style: .tinted) {\n            VStack(alignment: .leading, spacing: WakeSpacing.sm) {\n                Text(title).font(WakeTypography.title)\n                Text(message).font(WakeTypography.body).foregroundStyle(WakeColorTokens.textSecondary)\n                WakePrimaryActionButton(actionTitle, action: action)\n            }\n        }\n    }\n}\n\npublic struct WakeLoadingStateView: View {\n    public init() {}\n\n    public var body: some View {\n        WakeCard {\n            VStack(alignment: .leading, spacing: WakeSpacing.sm) {\n                SAISkeleton.line(width: 160, height: 18)\n                SAISkeleton.line(width: nil, height: 14)\n                SAISkeleton.line(width: 220, height: 14)\n                SAISkeleton.line(width: nil, height: 44)\n            }\n        }\n        .accessibilityLabel(\"Loading\")\n    }\n}\n\npublic struct WakeErrorStateView: View {\n    private let title: String\n    private let message: String\n    private let retryTitle: String\n    private let retry: () -> Void\n\n    public init(title: String, message: String, retryTitle: String, retry: @escaping () -> Void) {\n        self.title = title\n        self.message = message\n        self.retryTitle = retryTitle\n        self.retry = retry\n    }\n\n    public var body: some View {\n        WakeCard {\n            VStack(alignment: .leading, spacing: WakeSpacing.sm) {\n                WakeStatusChip(text: title, tone: .destructive)\n                Text(message).font(WakeTypography.body).foregroundStyle(WakeColorTokens.textSecondary)\n                WakeSecondaryActionButton(retryTitle, action: retry)\n            }\n        }\n        .accessibilityElement(children: .combine)\n        .accessibilityHint(\"Double tap to retry\")\n    }\n}\n\npublic struct WakePremiumCallout: View {\n    private let title: String\n    private let message: String\n    private let actionTitle: String\n    private let action: () -> Void\n\n    public init(title: String, message: String, actionTitle: String, action: @escaping () -> Void) {\n        self.title = title\n        self.message = message\n        self.actionTitle = actionTitle\n        self.action = action\n    }\n\n    public var body: some View {\n        WakeCard(style: .tinted) {\n            VStack(alignment: .leading, spacing: WakeSpacing.sm) {\n                WakeStatusChip(text: \"Premium\", tone: .premium)\n                Text(title).font(WakeTypography.title)\n                Text(message).font(WakeTypography.body).foregroundStyle(WakeColorTokens.textSecondary)\n                WakePrimaryActionButton(actionTitle, action: action)\n            }\n        }\n    }\n}\n\npublic struct WakeCompletionFeedback: View {\n    private let title: String\n    private let summary: String\n    private let nextActionTitle: String\n    private let secondaryTitle: String\n    private let onNext: () -> Void\n    private let onSecondary: () -> Void\n\n    public init(\n        title: String,\n        summary: String,\n        nextActionTitle: String,\n        secondaryTitle: String,\n        onNext: @escaping () -> Void,\n        onSecondary: @escaping () -> Void\n    ) {\n        self.title = title\n        self.summary = summary\n        self.nextActionTitle = nextActionTitle\n        self.secondaryTitle = secondaryTitle\n        self.onNext = onNext\n        self.onSecondary = onSecondary\n    }\n\n    public var body: some View {\n        WakeCard(style: .elevated) {\n            VStack(alignment: .leading, spacing: WakeSpacing.sm) {\n                WakeStatusChip(text: title, tone: .success)\n                Text(summary)\n                    .font(WakeTypography.body)\n                    .foregroundStyle(WakeColorTokens.textSecondary)\n                    .fixedSize(horizontal: false, vertical: true)\n                WakePrimaryActionButton(nextActionTitle, action: onNext)\n                WakeSecondaryActionButton(secondaryTitle, action: onSecondary)\n            }\n        }\n    }\n}\n\n#Preview(\"Wake Visual System States\") {\n    ScrollView {\n        VStack(alignment: .leading, spacing: WakeSpacing.md) {\n            WakeProgressStatus(\n                title: \"Wake Check In Progress\",\n                message: \"2 of 3 steps complete\",\n                progress: 0.66,\n                tone: .active\n            )\n            WakeRow(\n                title: \"Tomorrow 7:00 AM\",\n                subtitle: \"First task: Drink water and stretch\",\n                chipText: \"Active\",\n                chipTone: .active,\n                icon: \"alarm.fill\"\n            )\n            WakeEmptyStateView(\n                title: \"No wake commitments yet\",\n                message: \"Create your first wake task to start your routine.\",\n                actionTitle: \"Create your first wake\",\n                action: {}\n            )\n            WakeLoadingStateView()\n            WakeErrorStateView(\n                title: \"Sync failed\",\n                message: \"We could not refresh your latest wake status.\",\n                retryTitle: \"Retry\",\n                retry: {}\n            )\n            WakePremiumCallout(\n                title: \"Upgrade for reliability tools\",\n                message: \"Get deeper trends and repair planning while keeping the free wake loop.\",\n                actionTitle: \"See premium\",\n                action: {}\n            )\n            WakeCompletionFeedback(\n                title: \"Wake completed\",\n                summary: \"Completed at 7:02 AM. Next best action: set tomorrow’s wake.\",\n                nextActionTitle: \"Set next wake\",\n                secondaryTitle: \"View history\",\n                onNext: {},\n                onSecondary: {}\n            )\n        }\n        .padding(WakeSpacing.md)\n    }\n    .background(WakeColorTokens.backgroundPrimary)\n}\n\n#Preview(\"Wake Dynamic Type + Dark\") {\n    ScrollView {\n        WakeCompletionFeedback(\n            title: \"Wake completed\",\n            summary: \"Completed at 7:02 AM. Keep momentum with a clear next wake commitment for tomorrow.\",\n            nextActionTitle: \"Set next wake\",\n            secondaryTitle: \"Repair missed wake\",\n            onNext: {},\n            onSecondary: {}\n        )\n        .padding(WakeSpacing.md)\n    }\n    .dynamicTypeSize(.accessibility2)\n    .preferredColorScheme(.dark)\n    .background(WakeColorTokens.backgroundPrimary)\n}\n","exit_code":0,"status":"completed"}}
