{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-ios/Packages/DesignSystem/Sources/DesignSystem/Accessibility/WakeAccessibility.swift\"","aggregated_output":"import SwiftUI\n\npublic enum WakeFocusOrder {\n    public static let stateBanner: Double = 400\n    public static let primaryAction: Double = 300\n    public static let fallbackAction: Double = 200\n    public static let details: Double = 100\n}\n\npublic extension View {\n    func wakeMinimumTapTarget() -> some View {\n        frame(minWidth: 44, minHeight: 44)\n    }\n\n    func wakeFocusPriority(_ priority: Double) -> some View {\n        accessibilitySortPriority(priority)\n    }\n\n    func wakeStateAccessibility(label: String, hint: String? = nil) -> some View {\n        accessibilityLabel(Text(label))\n            .accessibilityHint(Text(hint ?? \"\"))\n            .accessibilityAddTraits(.isStaticText)\n    }\n\n    func wakeMotionAwareAnimation<V: Equatable>(_ value: V) -> some View {\n        modifier(WakeMotionAwareModifier(value: value))\n    }\n}\n\nprivate struct WakeMotionAwareModifier<V: Equatable>: ViewModifier {\n    let value: V\n    @Environment(\\.accessibilityReduceMotion) private var reduceMotion\n\n    func body(content: Content) -> some View {\n        content.animation(reduceMotion ? .none : .easeInOut(duration: 0.2), value: value)\n    }\n}\n","exit_code":0,"status":"completed"}}
