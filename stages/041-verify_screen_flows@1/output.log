keTypography.body\n        _ = WakeTypography.bodyStrong\n        _ = WakeTypography.detail\n        _ = WakeTypography.caption\n        _ = WakeTypography.status\n        _ = WakeTypography.tabular\n        #expect(WakeTypography.lineLimit(for: .body) >= 3)\n    }\n\n    @Test(\"Wake spacing scale preserves accessibility hit zones\")\n    func wakeSpacingSupportsHitTargets() {\n        #expect(WakeSpacing.xxs > 0)\n        #expect(WakeSpacing.xs > WakeSpacing.xxs)\n        #expect(WakeSpacing.sm > WakeSpacing.xs)\n        #expect(WakeSpacing.md > WakeSpacing.sm)\n        #expect(WakeSpacing.lg > WakeSpacing.md)\n        #expect(44 >= (WakeSpacing.md * 2))\n        #expect(WakeSpacing.divider > 0)\n    }\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' apps/waketask-ios/Packages/DesignSystem/Sources/DesignSystem/Components/WakeVisualComponents.swift\"","aggregated_output":"import SwiftUI\n\npublic struct WakeCard<Content: View>: View {\n    public enum Style {\n        case standard\n        case elevated\n        case tinted\n    }\n\n    private let style: Style\n    private let content: Content\n    @Environment(\\.colorScheme) private var colorScheme\n\n    public init(\n        style: Style = .standard,\n        @ViewBuilder content: () -> Content\n    ) {\n        self.style = style\n        self.content = content()\n    }\n\n    public var body: some View {\n        content\n            .padding(WakeSpacing.md)\n            .frame(maxWidth: .infinity, alignment: .leading)\n            .background(background)\n            .clipShape(RoundedRectangle(cornerRadius: DSRadius.md, style: .continuous))\n            .overlay(\n                RoundedRectangle(cornerRadius: DSRadius.md, style: .continuous)\n                    .stroke(WakeColorTokens.highContrastBorder.opacity(0.2), lineWidth: 1)\n            )\n            .shadow(\n                color: colorScheme == .dark ? WakeColorTokens.darkModeCardShadow : WakeColorTokens.lightModeCardShadow,\n                radius: style == .elevated ? 12 : 0,\n                x: 0,\n                y: style == .elevated ? 6 : 0\n            )\n    }\n\n    private var background: Color {\n        switch style {\n        case .standard: WakeColorTokens.surfaceCard\n        case .elevated: WakeColorTokens.surfaceCard\n        case .tinted: WakeColorTokens.actionSecondary\n        }\n    }\n}\n\npublic struct WakeRow: View {\n    private let title: String\n    private let subtitle: String?\n    private let chipText: String?\n    private let chipTone: WakeStateTone\n    private let icon: String?\n\n    public init(\n        title: String,\n        subtitle: String? = nil,\n        chipText: String? = nil,\n        chipTone: WakeStateTone = .active,\n        icon: String? = nil\n    ) {\n        self.title = title\n        self.subtitle = subtitle\n        self.chipText = chipText\n        self.chipTone = chipTone\n        self.icon = icon\n    }\n\n    public var body: some View {\n        HStack(alignment: .top, spacing: WakeSpacing.sm) {\n            if let icon {\n                Image(systemName: icon)\n                    .foregroundStyle(WakeColorTokens.textSecondary)\n                    .accessibilityHidden(true)\n            }\n\n            VStack(alignment: .leading, spacing: WakeSpacing.xxs) {\n                Text(title)\n                    .wakeType(WakeTypography.bodyStrong, lineLimit: WakeTypography.lineLimit(for: .body))\n                    .foregroundStyle(WakeColorTokens.textPrimary)\n                if let subtitle {\n                    Text(subtitle)\n                        .wakeType(WakeTypography.detail, lineLimit: WakeTypography.lineLimit(for: .subheadline))\n                        .foregroundStyle(WakeColorTokens.textSecondary)\n                }\n            }\n            Spacer(minLength: WakeSpacing.xs)\n            if let chipText {\n                WakeStatusChip(text: chipText, tone: chipTone)\n            }\n        }\n        .frame(minHeight: 44)\n        .accessibilityElement(children: .combine)\n        .accessibilityLabel(Text(accessibilitySummary))\n        .wakeMinimumTapTarget()\n    }\n\n    private var accessibilitySummary: String {\n        var segments = [title]\n        if let subtitle { segments.append(subtitle) }\n        if let chipText { segments.append(chipText) }\n        return segments.joined(separator: \", \")\n    }\n}\n\npublic struct WakeStatusChip: View {\n    let text: String\n    let tone: WakeStateTone\n\n    public init(text: String, tone: WakeStateTone) {\n        self.text = text\n        self.tone = tone\n    }\n\n    public var body: some View {\n        HStack(spacing: WakeSpacing.xxs) {\n            Image(systemName: tone.iconName)\n                .font(.caption2)\n                .accessibilityHidden(true)\n            Text(text)\n                .font(WakeTypography.status)\n                .lineLimit(2)\n        }\n        .foregroundStyle(tone.color)\n        .padding(.horizontal, WakeSpacing.xs)\n        .padding(.vertical, WakeSpacing.xxs)\n        .background(tone.color.opacity(0.13))\n        .clipShape(Capsule())\n        .overlay(\n            Capsule()\n                .stroke(WakeColorTokens.highContrastBorder.opacity(0.25), lineWidth: 1)\n        )\n        .accessibilityElement(children: .ignore)\n        .accessibilityLabel(Text(text))\n        .accessibilityAddTraits(.isStaticText)\n    }\n}\n\npublic struct WakeProgressStatus: View {\n    private let title: String\n    private let message: String\n    private let progress: Double\n    private let tone: WakeStateTone\n\n    public init(title: String, message: String, progress: Double, tone: WakeStateTone = .active) {\n        self.title = title\n        self.message = message\n        self.progress = progress\n        self.tone = tone\n    }\n\n    public var body: some View {\n        VStack(alignment: .leading, spacing: WakeSpacing.xs) {\n            Text(title)\n                .wakeType(WakeTypography.title, lineLimit: WakeTypography.lineLimit(for: .title3))\n            Text(message)\n                .wakeType(WakeTypography.detail, lineLimit: WakeTypography.lineLimit(for: .subheadline))\n                .foregroundStyle(WakeColorTokens.textSecondary)\n            ProgressView(value: min(max(progress, 0), 1))\n                .tint(tone.color)\n                .accessibilityValue(\"\\(Int(progress * 100))%\")\n        }\n        .accessibilityElement(children: .combine)\n        .wakeStateAccessibility(label: title, hint: message)\n    }\n}\n\npublic struct WakePrimaryActionButton: View {\n    private let title: LocalizedStringKey\n    private let role: ButtonRole?\n    private let action: () -> Void\n    @Environment(\\.accessibilityReduceMotion) private var reduceMotion\n\n    public init(_ title: LocalizedStringKey, role: ButtonRole? = nil, action: @escaping () -> Void) {\n        self.title = title\n        self.role = role\n        self.action = action\n    }\n\n    public init(_ title: String, role: ButtonRole? = nil, action: @escaping () -> Void) {\n        self.title = LocalizedStringKey(title)\n        self.role = role\n        self.action = action\n    }\n\n    public var body: some View {\n        Button(role: role) {\n            Haptics.tap()\n            action()\n        } label: {\n            Text(title)\n                .wakeType(WakeTypography.bodyStrong, lineLimit: WakeTypography.lineLimit(for: .body))\n                .frame(maxWidth: .infinity)\n                .frame(minHeight: 44)\n        }\n        .buttonStyle(.borderedProminent)\n        .tint(role == .destructive ? WakeColorTokens.destructive : WakeColorTokens.actionPrimary)\n        .scaleEffect(reduceMotion ? 1 : 0.999)\n        .accessibilityHint(Text(\"Activates the primary action\"))\n        .accessibilityAddTraits(.isButton)\n        .wakeFocusPriority(WakeFocusOrder.primaryAction)\n        .wakeMinimumTapTarget()\n    }\n}\n\npublic struct WakeSecondaryActionButton: View {\n    private let title: LocalizedStringKey\n    private let action: () -> Void\n\n    public init(_ title: LocalizedStringKey, action: @escaping () -> Void) {\n        self.title = title\n        self.action = action\n    }\n\n    public init(_ title: String, action: @escaping () -> Void) {\n        self.title = LocalizedStringKey(title)\n        self.action = action\n    }\n\n","exit_code":0,"status":"completed"}}
