{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-ios/Packages/DesignSystem/Sources/DesignSystem/Tokens/WakeVisualTokens.swift\"","aggregated_output":"import SwiftUI\n#if canImport(UIKit)\nimport UIKit\n#endif\n\npublic enum WakeColorTokens {\n    public static var backgroundPrimary: Color { DSColors.background }\n    public static var backgroundSecondary: Color { DSColors.surface }\n    public static var surfaceCard: Color { DSColors.surfaceElevated }\n    public static var surfaceMaterial: AnyShapeStyle { AnyShapeStyle(.ultraThinMaterial) }\n    public static var divider: Color { DSColors.borderSubtle }\n\n    public static var textPrimary: Color { DSColors.textPrimary }\n    public static var textSecondary: Color { DSColors.textSecondary }\n    public static var textMuted: Color { DSColors.textSecondary.opacity(0.72) }\n\n    public static var actionPrimary: Color { Color(red: 0.11, green: 0.58, blue: 0.53) }\n    public static var actionPrimaryPressed: Color { actionPrimary.opacity(0.84) }\n    public static var actionSecondary: Color { DSColors.surfaceTinted }\n\n    public static var success: Color { DSColors.success }\n    public static var warning: Color { DSColors.warning }\n    public static var destructive: Color { DSColors.danger }\n    public static var disabled: Color { DSColors.textSecondary.opacity(0.4) }\n    public static var premium: Color { DSColors.accentSecondary }\n    public static var activeTask: Color { actionPrimary }\n\n    public static var focusRing: Color { DSColors.accentPrimary.opacity(0.65) }\n    public static var highContrastBorder: Color { DSColors.textPrimary.opacity(0.72) }\n\n    public static var actionPrimaryText: Color { DSColors.background }\n    public static var stateOnColorText: Color { DSColors.background }\n    public static var darkModeCardShadow: Color { DSColors.shadow.opacity(0.34) }\n    public static var lightModeCardShadow: Color { DSColors.shadow.opacity(0.12) }\n}\n\npublic enum WakeStateTone {\n    case success\n    case warning\n    case destructive\n    case disabled\n    case premium\n    case active\n\n    public var color: Color {\n        switch self {\n        case .success: WakeColorTokens.success\n        case .warning: WakeColorTokens.warning\n        case .destructive: WakeColorTokens.destructive\n        case .disabled: WakeColorTokens.disabled\n        case .premium: WakeColorTokens.premium\n        case .active: WakeColorTokens.activeTask\n        }\n    }\n\n    public var iconName: String {\n        switch self {\n        case .success: \"checkmark.circle.fill\"\n        case .warning: \"exclamationmark.triangle.fill\"\n        case .destructive: \"xmark.octagon.fill\"\n        case .disabled: \"pause.circle.fill\"\n        case .premium: \"star.circle.fill\"\n        case .active: \"bolt.circle.fill\"\n        }\n    }\n}\n\npublic enum WakeTypography {\n    public static let hero = Font.title2.weight(.bold)\n    public static let title = Font.title3.weight(.semibold)\n    public static let body = Font.body\n    public static let bodyStrong = Font.body.weight(.semibold)\n    public static let detail = Font.subheadline\n    public static let caption = Font.caption\n    public static let status = Font.caption.weight(.semibold)\n    public static let tabular = Font.body.monospacedDigit()\n\n    public static func lineLimit(for textStyle: Font.TextStyle) -> Int {\n        switch textStyle {\n        case .caption, .caption2, .footnote:\n            return 2\n        case .title, .title2, .title3, .headline, .subheadline, .body:\n            return 3\n        default:\n            return 4\n        }\n    }\n}\n\npublic enum WakeSpacing {\n    public static let xxs = DSSpacing.xs\n    public static let xs = DSSpacing.sm\n    public static let sm = DSSpacing.md\n    public static let md = DSSpacing.lg\n    public static let lg = DSSpacing.xl\n    public static var divider: CGFloat {\n        #if canImport(UIKit)\n            1.0 / UIScreen.main.scale\n        #else\n            1\n        #endif\n    }\n}\n\npublic extension View {\n    func wakeType(_ style: Font, lineLimit: Int? = nil) -> some View {\n        self\n            .font(style)\n            .lineLimit(lineLimit)\n            .fixedSize(horizontal: false, vertical: true)\n    }\n}\n","exit_code":0,"status":"completed"}}
