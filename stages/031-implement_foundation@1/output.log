{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-iphone/.github/workflows/ci.yml\"","aggregated_output":"name: CI\n\non:\n  push:\n    branches: [ main, develop ]\n  pull_request:\n    branches: [ main, develop ]\n\n# Allow coverage comment step to post to PRs (read-only by default in newer repos).\npermissions:\n  contents: read\n  pull-requests: write\n\njobs:\n  test:\n    name: Build & Test (iOS 26.2)\n    runs-on: macos-15\n\n    steps:\n    - name: Checkout code\n      uses: actions/checkout@v4\n\n    - name: Select Xcode 26.2\n      run: sudo xcode-select -s /Applications/Xcode_26.2.app/Contents/Developer\n\n    - name: Show Xcode version\n      run: xcodebuild -version\n\n    - name: Cache SPM dependencies\n      uses: actions/cache@v4\n      with:\n        path: |\n          ~/Library/Developer/Xcode/DerivedData/**/SourcePackages\n          .build\n        key: ${{ runner.os }}-spm-${{ hashFiles('**/Package.resolved') }}\n        restore-keys: |\n          ${{ runner.os }}-spm-\n\n    - name: Build for testing\n      run: |\n        xcodebuild \\\n          -scheme SwiftAIBoilerplatePro \\\n          -destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=26.2' \\\n          -derivedDataPath .build \\\n          build-for-testing\n\n    - name: Run tests with coverage\n      run: |\n        xcodebuild \\\n          -scheme SwiftAIBoilerplatePro \\\n          -destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=26.2' \\\n          -derivedDataPath .build \\\n          -enableCodeCoverage YES \\\n          test-without-building\n\n    # Coverage reporting is best-effort: Xcode 26's xccov output format\n    # changed vs the previous grep pattern and we'd rather ship the release\n    # than gate on a broken metric. Test failures still fail the job above.\n    - name: Generate coverage report\n      continue-on-error: true\n      run: |\n        xcrun xccov view --report .build/Logs/Test/*.xcresult > coverage.txt || true\n        cat coverage.txt || true\n\n    - name: Extract coverage percentage\n      id: coverage\n      continue-on-error: true\n      run: |\n        COVERAGE=$(xcrun xccov view --report .build/Logs/Test/*.xcresult | grep -E \"^\\s+SwiftAIBoilerplatePro.app\" | awk '{print $2}' | sed 's/%//' || echo \"\")\n        echo \"COVERAGE=${COVERAGE:-0}\" >> $GITHUB_OUTPUT\n        echo \"Coverage: ${COVERAGE:-unknown}%\"\n\n    - name: Upload coverage report\n      if: always()\n      continue-on-error: true\n      uses: actions/upload-artifact@v4\n      with:\n        name: coverage-report\n        path: coverage.txt\n\n    - name: Comment coverage on PR\n      if: github.event_name == 'pull_request'\n      continue-on-error: true\n      uses: actions/github-script@v7\n      with:\n        script: |\n          const fs = require('fs');\n          let coverage = '(coverage report unavailable)';\n          try {\n            coverage = fs.readFileSync('coverage.txt', 'utf8');\n          } catch {}\n          const coveragePercent = '${{ steps.coverage.outputs.COVERAGE }}' || 'n/a';\n\n          const body = `## 📊 Test Coverage Report\n\n          **Overall Coverage: ${coveragePercent}%**\n\n          <details>\n          <summary>Detailed Coverage</summary>\n\n          \\`\\`\\`\n          ${coverage}\n          \\`\\`\\`\n\n          </details>\n          `;\n\n          github.rest.issues.createComment({\n            issue_number: context.issue.number,\n            owner: context.repo.owner,\n            repo: context.repo.repo,\n            body: body\n          });\n\n  test-ios18-fallback:\n    name: Build & Test (iOS 18.6 fallback path)\n    runs-on: macos-15\n\n    steps:\n    - name: Checkout code\n      uses: actions/checkout@v4\n\n    - name: Select Xcode 26.2\n      run: sudo xcode-select -s /Applications/Xcode_26.2.app/Contents/Developer\n\n    - name: Cache SPM dependencies\n      uses: actions/cache@v4\n      with:\n        path: |\n          ~/Library/Developer/Xcode/DerivedData/**/SourcePackages\n          .build-fallback\n        key: ${{ runner.os }}-spm-fallback-${{ hashFiles('**/Package.resolved') }}\n        restore-keys: |\n          ${{ runner.os }}-spm-fallback-\n\n    # Validates that SAIGlass's #available fallback to SwiftUI Material still\n    # compiles and runs on pre-iOS 26 simulators. No coverage gate — this job\n    # exists to catch regressions on the fallback path, not to block on metrics.\n    - name: Build for testing (iOS 18.6)\n      run: |\n        xcodebuild \\\n          -scheme SwiftAIBoilerplatePro \\\n          -destination 'platform=iOS Simulator,name=iPhone 16 Pro,OS=18.6' \\\n          -derivedDataPath .build-fallback \\\n          build-for-testing\n\n    - name: Run tests (iOS 18.6)\n      run: |\n        xcodebuild \\\n          -scheme SwiftAIBoilerplatePro \\\n          -destination 'platform=iOS Simulator,name=iPhone 16 Pro,OS=18.6' \\\n          -derivedDataPath .build-fallback \\\n          test-without-building\n\n  lint:\n    name: SwiftLint\n    runs-on: macos-15\n\n    steps:\n    - name: Checkout code\n      uses: actions/checkout@v4\n\n    - name: Install SwiftLint\n      run: brew install swiftlint\n\n    - name: Run SwiftLint\n      run: swiftlint lint --strict\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-iphone/.github/workflows/ios-ci.yml\"","aggregated_output":"name: iOS CI\n\non:\n  push:\n    branches: [ main ]\n  pull_request:\n\njobs:\n  build-and-test:\n    runs-on: macos-15\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Select Xcode 26.2\n        run: sudo xcode-select -s /Applications/Xcode_26.2.app || sudo xcode-select -s \"$(ls -d /Applications/Xcode_*.app | sort -V | tail -1)\"\n\n      - name: Cache SPM\n        uses: actions/cache@v4\n        with:\n          path: |\n            ~/Library/Developer/Xcode/DerivedData\n            ~/Library/Caches/org.swift.swiftpm\n            ~/.swiftpm\n          key: ${{ runner.os }}-spm-${{ hashFiles('**/Package.resolved') }}\n\n      - name: Resolve packages\n        run: xcodebuild -resolvePackageDependencies -project SwiftAIBoilerplatePro.xcodeproj\n\n      - name: Build (Debug)\n        run: |\n          set -o pipefail\n          xcodebuild \\\n            -project SwiftAIBoilerplatePro.xcodeproj \\\n            -scheme SwiftAIBoilerplatePro \\\n            -configuration Debug \\\n            -sdk iphonesimulator \\\n            -destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=26.2' \\\n            CODE_SIGNING_ALLOWED=NO \\\n            build | xcpretty\n\n      - name: Test (Unit)\n        run: |\n          set -o pipefail\n          xcodebuild \\\n            -project SwiftAIBoilerplatePro.xcodeproj \\\n            -scheme SwiftAIBoilerplatePro \\\n            -sdk iphonesimulator \\\n            -destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=26.2' \\\n            CODE_SIGNING_ALLOWED=NO \\\n            test | xcpretty --color\n\n      - name: Store logs\n        if: always()\n        uses: actions/upload-artifact@v4\n        with:\n          name: xcode-logs\n          path: |\n            ~/Library/Developer/Xcode/DerivedData/**/Logs/Test/*\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-iphone/.github/workflows/coverage-report.yml\"","aggregated_output":"name: Weekly Coverage Report\n\non:\n  schedule:\n    # Run every Monday at 9 AM UTC\n    - cron: '0 9 * * 1'\n  workflow_dispatch:\n\njobs:\n  coverage:\n    name: Generate Full Coverage Report\n    runs-on: macos-15\n\n    steps:\n    - name: Checkout code\n      uses: actions/checkout@v4\n\n    - name: Select Xcode 26.2\n      run: sudo xcode-select -s /Applications/Xcode_26.2.app/Contents/Developer\n\n    - name: Run all tests with coverage\n      run: |\n        xcodebuild \\\n          -scheme SwiftAIBoilerplatePro \\\n          -destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=26.2' \\\n          -derivedDataPath .build \\\n          -enableCodeCoverage YES \\\n          test\n    \n    - name: Generate detailed coverage report\n      run: |\n        xcrun xccov view --report .build/Logs/Test/*.xcresult > coverage-detailed.txt\n        xcrun xccov view --report --json .build/Logs/Test/*.xcresult > coverage.json\n    \n    - name: Generate HTML coverage report\n      run: |\n        xcrun xccov view --report .build/Logs/Test/*.xcresult | \\\n        awk '\n        BEGIN {\n          print \"<html><head><title>Coverage Report</title>\"\n          print \"<style>\"\n          print \"body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; margin: 40px; }\"\n          print \"table { border-collapse: collapse; width: 100%; }\"\n          print \"th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }\"\n          print \"th { background-color: #007AFF; color: white; }\"\n          print \".high { color: #34C759; }\"\n          print \".medium { color: #FF9500; }\"\n          print \".low { color: #FF3B30; }\"\n          print \"</style></head><body>\"\n          print \"<h1>📊 Test Coverage Report</h1>\"\n          print \"<p>Generated: \" strftime(\"%Y-%m-%d %H:%M:%S\") \"</p>\"\n          print \"<table><tr><th>Target</th><th>Coverage</th><th>Status</th></tr>\"\n        }\n        /\\.app|\\.framework/ {\n          target = $1\n          coverage = $2\n          gsub(/%/, \"\", coverage)\n          status_class = coverage >= 85 ? \"high\" : coverage >= 70 ? \"medium\" : \"low\"\n          status_text = coverage >= 85 ? \"✅ Good\" : coverage >= 70 ? \"⚠️  Medium\" : \"❌ Low\"\n          print \"<tr><td>\" target \"</td><td class=\\\"\" status_class \"\\\">\" $2 \"</td><td>\" status_text \"</td></tr>\"\n        }\n        END {\n          print \"</table></body></html>\"\n        }\n        ' > coverage-report.html\n    \n    - name: Create coverage summary\n      run: |\n        echo \"# Coverage Summary\" > coverage-summary.md\n        echo \"\" >> coverage-summary.md\n        echo \"Generated: $(date)\" >> coverage-summary.md\n        echo \"\" >> coverage-summary.md\n        echo \"## Overall Statistics\" >> coverage-summary.md\n        echo \"\" >> coverage-summary.md\n        echo \"\\`\\`\\`\" >> coverage-summary.md\n        xcrun xccov view --report .build/Logs/Test/*.xcresult | head -20 >> coverage-summary.md\n        echo \"\\`\\`\\`\" >> coverage-summary.md\n        echo \"\" >> coverage-summary.md\n        echo \"## Modules Below 85% Threshold\" >> coverage-summary.md\n        echo \"\" >> coverage-summary.md\n        xcrun xccov view --report .build/Logs/Test/*.xcresult | \\\n          awk '/\\.app|\\.framework/ { gsub(/%/, \"\", $2); if ($2 < 85) print \"- \" $1 \": \" $2 \"%\" }' >> coverage-summary.md || true\n    \n    - name: Upload artifacts\n      uses: actions/upload-artifact@v4\n      with:\n        name: coverage-reports\n        path: |\n          coverage-detailed.txt\n          coverage.json\n          coverage-report.html\n          coverage-summary.md\n    \n    - name: Create GitHub Issue if coverage is low\n      if: always()\n      uses: actions/github-script@v7\n      with:\n        script: |\n          const fs = require('fs');\n          const summary = fs.readFileSync('coverage-summary.md', 'utf8');\n          \n          // Check if there are modules below threshold\n          if (summary.includes('## Modules Below 85% Threshold') && \n              !summary.includes('## Modules Below 85% Threshold\\n\\n##')) {\n            \n            await github.rest.issues.create({\n              owner: context.repo.owner,\n              repo: context.repo.repo,\n              title: '⚠️ Weekly Coverage Report: Modules Below Threshold',\n              body: summary,\n              labels: ['test', 'coverage', 'needs-attention']\n            });\n          }\n\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' apps/waketask-iphone/.github/workflows/release-distribution.yml\"","aggregated_output":"name: Send Release Distribution Emails\n\non:\n  release:\n    types: [published]\n  workflow_dispatch:\n    inputs:\n      tag:\n        description: 'Release tag to notify buyers about (e.g. v2.0.0)'\n        required: true\n        type: string\n\njobs:\n  notify-buyers:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Resolve release metadata\n        id: release\n        env:\n          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n          EVENT_NAME: ${{ github.event_name }}\n          EVENT_TAG: ${{ github.event.release.tag_name }}\n          EVENT_TITLE: ${{ github.event.release.name }}\n          EVENT_URL: ${{ github.event.release.html_url }}\n          EVENT_BODY: ${{ github.event.release.body }}\n          DISPATCH_TAG: ${{ inputs.tag }}\n        run: |\n          set -euo pipefail\n\n          if [ \"$EVENT_NAME\" = \"workflow_dispatch\" ]; then\n            TAG=\"$DISPATCH_TAG\"\n            RELEASE_JSON=$(gh api \"repos/$GITHUB_REPOSITORY/releases/tags/$TAG\")\n            RELEASE_TITLE=$(printf '%s' \"$RELEASE_JSON\" | jq -r '.name // \"\"')\n            RELEASE_URL=$(printf '%s' \"$RELEASE_JSON\" | jq -r '.html_url // \"\"')\n            RELEASE_BODY=$(printf '%s' \"$RELEASE_JSON\" | jq -r '.body // \"\"')\n          else\n            TAG=\"$EVENT_TAG\"\n            RELEASE_TITLE=\"$EVENT_TITLE\"\n            RELEASE_URL=\"$EVENT_URL\"\n            RELEASE_BODY=\"$EVENT_BODY\"\n          fi\n\n          VERSION=\"${TAG#v}\"\n\n          # Multi-line values need heredoc syntax in GITHUB_OUTPUT.\n          {\n            echo \"version=$VERSION\"\n            echo \"url=$RELEASE_URL\"\n            echo \"title<<RELEASE_TITLE_EOF\"\n            echo \"$RELEASE_TITLE\"\n            echo \"RELEASE_TITLE_EOF\"\n            echo \"body<<RELEASE_BODY_EOF\"\n            echo \"$RELEASE_BODY\"\n            echo \"RELEASE_BODY_EOF\"\n          } >> \"$GITHUB_OUTPUT\"\n\n          echo \"Resolved tag=$TAG version=$VERSION\"\n          echo \"Title: $RELEASE_TITLE\"\n          echo \"URL:   $RELEASE_URL\"\n\n      - name: Send distribution emails\n        env:\n          BASE_URL: ${{ secrets.BASE_URL }}\n          ADMIN_SECRET: ${{ secrets.ADMIN_SECRET }}\n          VERSION: ${{ steps.release.outputs.version }}\n          HEADLINE: ${{ steps.release.outputs.title }}\n          CHANGELOG_URL: ${{ steps.release.outputs.url }}\n          BODY: ${{ steps.release.outputs.body }}\n        run: |\n          set -euo pipefail\n\n          # Build the JSON payload with jq so every value (including the\n          # multi-line release body, which contains backticks, parens, and\n          # other shell metacharacters) is escaped correctly. Extract the\n          # bullet list from the body as the `features` array, falling back\n          # to a single placeholder entry when there are no bullets.\n          PAYLOAD=$(jq -n \\\n            --arg version \"$VERSION\" \\\n            --arg headline \"$HEADLINE\" \\\n            --arg body \"$BODY\" \\\n            --arg changelogUrl \"$CHANGELOG_URL\" \\\n            '{\n              version: $version,\n              headline: $headline,\n              features: (\n                $body\n                | split(\"\\n\")\n                | map(select(startswith(\"- \") or startswith(\"* \")))\n                | map(ltrimstr(\"- \") | ltrimstr(\"* \"))\n                | if length == 0 then [\"See changelog for details\"] else . end\n              ),\n              changelogUrl: $changelogUrl\n            }')\n\n          echo \"Payload summary:\"\n          printf '%s' \"$PAYLOAD\" | jq '{version, headline, changelogUrl, featureCount: (.features | length)}'\n\n          # Dump response headers to /tmp/curl-headers.txt for debugging\n          # (3xx responses surface their Location target there).\n          #\n          # -L                            — follow redirects\n          # --post301/302/303             — re-send POST on 301/302/303 too\n          #                                 (307/308 preserve method by default)\n          # --max-redirs 5                — safety cap\n          # -D /tmp/curl-headers.txt      — dump headers from every hop\n          RESPONSE=$(curl -sS -L \\\n            --post301 --post302 --post303 \\\n            --max-redirs 5 \\\n            -D /tmp/curl-headers.txt \\\n            -w \"\\n%{http_code}\" -X POST \\\n            \"$BASE_URL/api/distribution/send\" \\\n            -H \"Content-Type: application/json\" \\\n            -H \"x-admin-secret: $ADMIN_SECRET\" \\\n            --data-binary \"$PAYLOAD\")\n\n          HTTP_CODE=$(printf '%s' \"$RESPONSE\" | tail -1)\n          RESPONSE_BODY=$(printf '%s' \"$RESPONSE\" | sed '$d')\n\n          echo \"Status: $HTTP_CODE\"\n          echo \"Response: $RESPONSE_BODY\"\n          echo \"\"\n          echo \"=== curl response headers (all hops) ===\"\n          cat /tmp/curl-headers.txt || true\n\n          if [ \"$HTTP_CODE\" != \"200\" ]; then\n            echo \"::error::Distribution email API returned $HTTP_CODE\"\n            exit 1\n          fi\n","exit_code":0,"status":"completed"}}
