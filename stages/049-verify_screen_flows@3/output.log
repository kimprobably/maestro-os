 ],\n      \"states\": {\n        \"empty\": \"Show editable recommended defaults so users can complete setup quickly.\",\n        \"loading\": \"Show step card skeleton and stable CTA placement while defaults load.\",\n        \"error\": \"Show inline save/validation errors with retry while preserving entered values.\"\n      },\n      \"copy_direction\": \"Calm and factual tone with short labels; avoid guilt, pressure, and coercive wording; preserve localization headroom for expanded strings.\",\n      \"accessibility_requirements\": [\n        \"VoiceOver announces step count, current choice, and CTA outcome.\",\n        \"Focus order is title to controls to primary CTA to secondary actions.\",\n        \"Dynamic Type supports multiline fields and untruncated CTA labels.\",\n        \"Reduced motion removes step-slide animations.\",\n        \"Primary CTA remains reachable in lower-thumb zone and meets 44x44pt target size.\"\n      ],\n      \"screenshot_acceptance_criteria\": [\n        \"Primary CTA is visible without scrolling.\",\n        \"Step title and CTA labels are readable at common Dynamic Type sizes.\",\n        \"Skip path is visible and clearly secondary.\",\n        \"Light and dark mode both preserve contrast and hierarchy.\",\n        \"Loading and error states keep card and button positions stable.\",\n        \"Visual composition does not clone any named competitor reference.\"\n      ]\n    },\n    {\n      \"id\": \"home\",\n      \"purpose\": \"Orient users to the next wake commitment and provide immediate preparation or start action.\",\n      \"hierarchy\": [\n        \"Next Wake Commitment module\",\n        \"Commitment status and due-time context\",\n        \"Primary commitment action\",\n        \"Secondary history and profile shortcuts\"\n      ],\n      \"primary_action\": \"Open the next wake commitment flow from the dominant home module.\",\n      \"secondary_actions\": [\n        \"View all tasks link beneath commitment module\",\n        \"History preview navigation\",\n        \"Profile/settings access\"\n      ],\n      \"states\": {\n        \"empty\": \"Show no-commitment message with Create your first wake action.\",\n        \"loading\": \"Show commitment card skeleton with reserved status and CTA space.\",\n        \"error\": \"Show sync failure banner with Retry while preserving last-known commitment summary.\"\n      },\n      \"copy_direction\": \"Use operational clarity and plain scheduling language; avoid vague hype or pressure; localize date/time formats natively.\",\n      \"accessibility_requirements\": [\n        \"VoiceOver reads commitment title, due time, and status as one coherent summary.\",\n        \"Focus order prioritizes commitment content before analytics tiles.\",\n        \"Dynamic Type allows multiline status text without clipping action labels.\",\n        \"Status chips include text/icon semantics and are not color-only.\",\n        \"Primary action remains one-handed reachable and target-size compliant.\"\n      ],\n      \"screenshot_acceptance_criteria\": [\n        \"Next Wake Commitment is the first visible module.\",\n        \"Primary action is above the fold.\",\n        \"Status meaning is clear without depending on color alone.\",\n        \"No key text truncation at common Dynamic Type sizes.\",\n        \"Dark and light mode screenshots remain readable.\",\n        \"Layout remains stable between loading/error and loaded states.\"\n      ]\n    },\n    {\n      \"id\": \"primary_list\",\n      \"purpose\": \"Let users scan and manage wake tasks by readiness with quick resume or edit actions.\",\n      \"hierarchy\": [\n        \"Readiness sections Tonight, Later, and Paused\",\n        \"Task rows with status chips and quick actions\",\n        \"Primary create action\",\n        \"Secondary filter and sort controls\"\n      ],\n      \"primary_action\": \"Resume or open the most relevant task from readiness-grouped rows.\",\n      \"secondary_actions\": [\n        \"Pause or Resume row actions\",\n        \"Edit from row overflow\",\n        \"Filter and sorting controls\"\n      ],\n      \"states\": {\n        \"empty\": \"Show readiness explanation and create-task CTA.\",\n        \"loading\": \"Show section and row skeletons with stable heights.\",\n        \"error\": \"Show section-level load error with retry while unaffected sections stay visible.\"\n      },\n      \"copy_direction\": \"Prefer plain status terms and concise chips; avoid jargon and punitive miss language; keep labels short for localization.\",\n      \"accessibility_requirements\": [\n        \"VoiceOver announces section, task title, status, and available quick action.\",\n        \"Focus order is section header then rows in reading order.\",\n        \"Dynamic Type supports multiline row titles and metadata.\",\n        \"Row controls meet minimum touch targets and have explicit labels.\",\n        \"Pause/Resume confirmation is never haptic-only.\"\n      ],\n      \"screenshot_acceptance_criteria\": [\n        \"Readiness grouping is visually clear via headings, not color alone.\",\n        \"Status chip text is readable in at least one visible row.\",\n        \"Empty-state create action is visible above fold.\",\n        \"Dynamic Type does not clip row actions or key labels.\",\n        \"Loading and error variants preserve row geometry.\",\n        \"Screen styling does not replicate a competitor list composition.\"\n      ]\n    },\n    {\n      \"id\": \"create_edit\",\n      \"purpose\": \"Guide users through linear wake-task authoring from intent to review with progressive disclosure.\",\n      \"hierarchy\": [\n        \"Step sequence indicator\",\n        \"Current-step form fields\",\n        \"Primary continue or save action\",\n        \"Secondary back, cancel, and advanced options\"\n      ],\n      \"primary_action\": \"Complete the current step and advance to final task save.\",\n      \"secondary_actions\": [\n        \"Advanced options disclosure below core fields\",\n        \"Back navigation\",\n        \"Cancel action in navigation bar\"\n      ],\n      \"states\": {\n        \"empty\": \"Show starter defaults and concise field guidance.\",\n        \"loading\": \"Show form skeletons with fixed footer CTA area.\",\n        \"error\": \"Show inline field errors and save-failure summary with retry.\"\n      },\n      \"copy_direction\": \"Use concise instructional language; avoid alarmist or legalistic phrasing; keep units/time terms localization-friendly.\",\n      \"accessibility_requirements\": [\n        \"VoiceOver reads field label, value, and validation status.\",\n        \"Focus order follows step header to fields to primary action.\",\n        \"Dynamic Type supports multiline helper text and avoids control overlap.\",\n        \"Reduced motion removes step transition animations.\",\n        \"Primary CTA remains in one-handed reach and meets minimum target size.\"\n      ],\n      \"screenshot_acceptance_criteria\": [\n        \"Current step context is clearly visible.\",\n        \"Primary continue/save action is visible without scrolling.\",\n        \"Error state preserves entered data and correction guidance.\",\n        \"No critical field labels truncate at common Dynamic Type sizes.\",\n        \"Loading and loaded layouts keep stable vertical rhythm.\",\n        \"Visual hierarchy avoids clone-like replication of reference flows.\"\n      ]\n    },\n    {\n      \"id\": \"active_task\",\n      \"purpose\": \"Enable rapid wake execution with one dominant action, explicit state clarity, and a safe fallback.\",\n      \"hierarchy\": [\n        \"Current-state banner\",\n        \"Dominant wake confirmation CTA\",\n        \"Fallback action\",\n        \"Minimal supporting context\"\n      ],\n      \"primary_action\": \"Confirm current wake step completion with the single dominant CTA.\",\n      \"secondary_actions\": [\n        \"Need extra minute fallback action\",\n        \"Optional details disclosure\"\n      ],\n      \"states\": {\n        \"empty\": \"If no active wake exists, redirect to home with clear explanatory text.\",\n        \"loading\": \"Show state banner and disabled CTA placeholders while syncing.\",\n        \"error\": \"Show explicit sync or permission failure with retry and safe fallback path.\"\n      },\n      \"copy_direction\": \"Use short direct verbs and immediate context; avoid shame, panic theatrics, and dense explanatory text.\",\n      \"accessibility_requirements\": [\n        \"VoiceOver announces state banner before interactive controls.\",\n        \"Focus order is state to primary CTA to fallback to details.\",\n        \"Primary CTA and state text meet contrast requirements in both themes.\",\n        \"Reduced motion removes transition effects while preserving text state updates.\",\n        \"Primary and fallback controls meet target size and one-handed reach constraints.\"\n      ],\n      \"screenshot_acceptance_criteria\": [\n        \"Exactly one visually dominant primary action is present.\",\n        \"Fallback action is visible and clearly secondary.\",\n        \"State meaning is clear without motion or color-only dependency.\",\n        \"Dark and light mode both show legible CTA and state banner.\",\n        \"Loading and error variants keep button and banner alignment stable.\",\n        \"Screen does not visually clone known alarm-challenge competitors.\"\n      ]\n    },\n    {\n      \"id\": \"completion\",\n      \"purpose\": \"Confirm wake outcome and direct the user to one next-best continuity action.\",\n      \"hierarchy\": [\n        \"Completion confirmation\",\n        \"Outcome summary\",\n        \"Primary next-best action\",\n        \"Secondary history or repair options\"\n      ],\n      \"primary_action\": \"Take the recommended next step such as Set next wake or Quick reflection.\",\n      \"secondary_actions\": [\n        \"View history\",\n    