e/Packages/DesignSystem/Sources/DesignSystem/Motion/SAIMotion.swift:71:private struct PressedEffectModifier: ViewModifier {\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Motion/SAIMotion.swift:73:    @Environment(\\.accessibilityReduceMotion) private var reduceMotion\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Motion/SAIMotion.swift:100:private struct ShimmerModifier: ViewModifier {\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Motion/SAIMotion.swift:102:    @Environment(\\.accessibilityReduceMotion) private var reduceMotion\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Components/SAIToast.swift:104:public struct SAIToast: View {\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Components/SAIToast.swift:109:    @Environment(\\.accessibilityReduceMotion) private var reduceMotion\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Components/SAIToast.swift:178:public struct ToastContainerView<Content: View>: View {\napps/waketask-iphone/Packages/DesignSystem/Tests/DesignSystemTests/ChatBubbleSnapshotTests.swift:62:        // Test with accessibility large text sizes\napps/waketask-iphone/Packages/DesignSystem/Tests/DesignSystemTests/ChatBubbleSnapshotTests.swift:73:        // Verify accessibility labels are set correctly\napps/waketask-iphone/Packages/DesignSystem/Tests/DesignSystemTests/ChatBubbleSnapshotTests.swift:83:        // - Bubble respects accessibility text size\napps/waketask-iphone/Packages/DesignSystem/Tests/DesignSystemTests/TokenTests.swift:188:        // Medium should be at least 44pt for accessibility\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Materials/SAIGlass.swift:33:private struct SAIGlassModifier<ClipShape: Shape>: ViewModifier {\napps/waketask-iphone/Packages/DesignSystem/Sources/DesignSystem/Materials/SAIGlass.swift:86:public struct SAIGlassContainer<Content: View>: View {\n","exit_code":0,"status":"completed"}}
