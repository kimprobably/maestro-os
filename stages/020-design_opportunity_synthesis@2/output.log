{"type":"item.started","item":{"id":"item_18","type":"command_execution","command":"/bin/bash -lc \"cat > .workflow/iphone-app-ux-studio/research/reference-pack.json <<'EOF'\n{\n  \\\"references\\\": [\n    {\n      \\\"id\\\": \\\"ref-competitor-001\\\",\n      \\\"title\\\": \\\"Deterministic onboarding-first launch\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"onboarding\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Intake and competitor artifact together show the launch route moves through onboarding before auth and shell access, creating a strict first-run sequence.\\\",\n      \\\"what_to_adapt\\\": \\\"Keep sequencing visible and guided but add a skip-safe calm path so users can proceed after first wake intent is known.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not lock users behind rigid pages before core value screens are reachable.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-002\\\",\n      \\\"title\\\": \\\"Tab-shell task workspace\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"home\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Current app structure uses Home, Runs, and Profile tabs; competitor notes emphasize clear navigation boundaries for task flows.\\\",\n      \\\"what_to_adapt\\\": \\\"Preserve the tab mental model but strengthen labels and defaults so users immediately find active mission paths.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not use ambiguous tab semantics that hide wake execution under generic actions.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-003\\\",\n      \\\"title\\\": \\\"Active mission priority\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Wake dashboard and active-task references include mission progression and completion states, with success and fail transitions already modeled in current screens.\\\",\n      \\\"what_to_adapt\\\": \\\"Prioritize one dominant action while active with immediate status feedback and next-step controls.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not clutter the active screen with non-essential navigation or settings access.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-004\\\",\n      \\\"title\\\": \\\"Profile operational/account separation\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"profile_settings\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Intake shows profile, help, legal, and destructive actions are co-located, which can overload users after wake operations.\\\",\n      \\\"what_to_adapt\\\": \\\"Separate mission operations from legal/account actions with calmer section hierarchy.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not place high-risk or account actions adjacent to core wake controls.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-001\\\",\n      \\\"title\\\": \\\"Progressive wake setup path\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"create_edit\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback Page Flows notes model multi-step setup in calm sequence with task intent before strictness controls.\\\",\n      \\\"what_to_adapt\\\": \\\"Use staged task creation: choose intent, then configure optional strictness, then finalize mission details.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not show all setup controls in a single high-pressure screen.\\\",\n      \\\"provider\\\": \\\"pageflows\\\",\n      \\\"tags\\\": [\\\"pageflows\\\", \\\"calm_setup\\\", \\\"progressive_disclosure\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-002\\\",\n      \\\"title\\\": \\\"Single-action urgent wake execution\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback references recommend a single dominant interaction in mission-active phases and visible progress markers.\\\",\n      \\\"what_to_adapt\\\": \\\"Keep one primary wake CTA and clear progress text during active state.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not add parallel action trees that interrupt urgent completion.\\\",\n      \\\"provider\\\": \\\"page flows\\\",\n      \\\"tags\\\": [\\\"page flows\\\", \\\"urgent_wake\\\", \\\"single_action\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-003\\\",\n      \\\"title\\\": \\\"Completion recovery without shame\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"completion\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback notes describe confirmation-first recovery messaging for missed tasks and calm restart options.\\\",\n      \\\"what_to_adapt\\\": \\\"Confirm result first and then surface an immediate, low-friction retry path.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not use punitive or punitive-toned messaging after failure.\\\",\n      \\\"provider\\\": \\\"page flows\\\",\n      \\\"tags\\\": [\\\"page flows\\\", \\\"completion\\\", \\\"recovery\\\", \\\"accountability\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-004\\\",\n      \\\"title\\\": \\\"History that teaches and repairs\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"history_streaks\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback pattern notes indicate history/streak views should include meaning and repair context rather than passive reward counters.\\\",\n      \\\"what_to_adapt\\\": \\\"Expose why a miss occurred and a concrete next-step repair for consistency.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not depend on decorative badges alone for accountability behavior.\\\",\n      \\\"provider\\\": \\\"pageflows\\\",\n      \\\"tags\\\": [\\\"pageflows\\\", \\\"history_streaks\\\", \\\"repair\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-mobbin-001\\\",\n      \\\"title\\\": \\\"Fallback calm setup guidance\\\",\n      \\\"source\\\": \\\"mobbin\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"onboarding\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/mobbin-mcp-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Mobbin fallback artifact marks setup sequencing as bounded and reversible at first run, with explicit limits around unverified private copies.\\\",\n      \\\"what_to_adapt\\\": \\\"Keep initial setup minimal and reversible until wake value is experienced once.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not reproduce exact Mobbin visual systems or copy protected interaction choreography.\\\",\n      \\\"provider\\\": \\\"mobbin_fallback\\\",\n      \\\"tags\\\": [\\\"mobbin\\\", \\\"calm_setup\\\", \\\"fallback\\\"],\n      \\\"url\\\": \\\"https://api.mobbin.com/mcp\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-mobbin-002\\\",\n      \\\"title\\\": \\\"Fallback urgent execution focus\\\",\n      \\\"source\\\": \\\"mobbin\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/mobbin-mcp-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Fallback Mobbin notes stress one focused mission action while users are in urgent execution mode.\\\",\n      \\\"what_to_adapt\\\": \\\"Use a single high-contrast control in active mode and avoid decision branching.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not copy private screen mechanics or transitions from non-consumable references.\\\",\n      \\\"provider\\\": \\\"mobbin_fallback\\\",\n      \\\"tags\\\": [\\\"mobbin\\\", \\\"urgent_wake\\\", \\\"focus\\\"],\n      \\\"url\\\": \\\"https://api.mobbin.com/mcp\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-mobbin-003\\\",\n      \\\"title\\\": \\\"Fallback recovery-first tone\\\",\n      \\\"source\\\": \\\"mobbin\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"completion\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/mobbin-mcp-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Fallback artifact highlights post-failure trust-preserving recovery paths and non-shaming language expectations.\\\",\n      \\\"what_to_adapt\\\": \\\"Frame miss handling as next-step continuity with immediate recover option.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not add anxiety-heavy copy or threat-like timers in recovery states.\\\",\n      \\\"provider\\\": \\\"mobbin_fallback\\\",\n      \\\"tags\\\": [\\\"mobbin\\\", \\\"recovery\\\", \\\"completion\\\"],\n      \\\"url\\\": \\\"https://api.mobbin.com/mcp\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-mobbin-004\\\",\n      \\\"title\\\": \\\"Fallback accountability clarity\\\",\n      \\\"source\\\": \\\"mobbin\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"history_streaks\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/mobbin-mcp-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Fallback notes tie accountability screens to reliability signaling and user trust rather than punishment.\\\",\n      \\\"what_to_adapt\\\": \\\"Show repair context and reliability reasoning next to streak and history indicators.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not copy proprietary streak visuals or claim exact reward cadence.\\\",\n      \\\"provider\\\": \\\"mobbin_fallback\\\",\n      \\\"tags\\\": [\\\"mobbin\\\", \\\"accountability\\\", \\\"history\\\"],\n      \\\"url\\\": \\\"https://api.mobbin.com/mcp\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-app-store-001\\\",\n      \\\"title\\\": \\\"Review evidence gap for onboarding and value framing\\\",\n      \\\"source\\\": \\\"app_store\\\",\n      \\\"source_type\\\": \\\"review_mining\\\",\n      \\\"category\\\": \\\"review_mining\\\",\n      \\\"screen_type\\\": \\\"onboarding\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/app-store-review-mining.md\\\",\n      \\\"evidence_summary\\\": \\\"Review mining stage is present but does not deliver verified review-theme corpus in this branch.\\\",\n      \\\"what_to_adapt\\\": \\\"Use onboarding hypotheses as provisional and test with explicit retention instrumentation.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not publish unsupported retention claims as design conclusions.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-app-store-002\\\",\n      \\\"title\\\": \\\"Review evidence gap for post-task recovery\\\",\n      \\\"source\\\": \\\"app_store\\\",\n      \\\"source_type\\\": \\\"review_mining\\\",\n      \\\"category\\\": \\\"review_mining\\\",\n      \\\"screen_type\\\": \\\"completion\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/app-store-review-mining.md\\\",\n      \\\"evidence_summary\\\": \\\"No App Store corpus was verified before synthesis; recovery and support hypotheses need follow-up validation.\\\",\n      \\\"what_to_adapt\\\": \\\"Prioritize recovery UX and evidence-gathering before locking incentive mechanics.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not design punitive reward flow without actual review confirmation.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-apple-hig-001\\\",\n      \\\"title\\\": \\\"Interruption-safe task controls\\\",\n      \\\"source\\\": \\\"apple_hig\\\",\n      \\\"source_type\\\": \\\"platform_guidance\\\",\n      \\\"category\\\": \\\"platform_guidance\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/apple-hig-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Apple HIG source file is fallback-based in this branch and notes emphasis on accessible, interruption-safe controls in active states.\\\",\n      \\\"what_to_adapt\\\": \\\"Preserve clear labels, semantics, and predictable action ordering in wake moments.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not over-customize controls or transitions that reduce discoverability.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-behavioral-001\\\",\n      \\\"title\\\": \\\"Behavioral separation by mode\\\",\n      \\\"source\\\": \\\"behavioral_research\\\",\n      \\\"source_type\\\": \\\"behavioral_ux\\\",\n      \\\"category\\\": \\\"behavioral_ux\\\",\n      \\\"screen_type\\\": \\\"completion\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/behavioral-ux-research.md\\\",\n      \\\"evidence_summary\\\": \\\"Behavioral notes distinguish calm setup tone from urgent execution and stress shame-free recovery cues.\\\",\n      \\\"what_to_adapt\\\": \\\"Use two interaction profiles: low-pressure setup and urgent-task urgency, with calm recovery framing.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not reuse anxiety-heavy reminders or penalty framing for missed missions.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-synthesis-001\\\",\n      \\\"title\\\": \\\"Evidence-limited synthesis posture\\\",\n      \\\"source\\\": \\\"synthesis\\\",\n      \\\"source_type\\\": \\\"opportunity\\\",\n      \\\"category\\\": \\\"opportunity\\\",\n      \\\"screen_type\\\": \\\"home\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/design-opportunity-synthesis.md\\\",\n      \\\"evidence_summary\\\": \\\"Design synthesis stage explicitly marks evidence gaps from baseline capture and unmaterialized external artifacts.\\\",\n      \\\"what_to_adapt\\\": \\\"Prioritize changes with direct code-backed support and mark all inferred claims clearly.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not treat inferred behavior as verified product truth.\\\"\n    }\n  ],\n  \\\"observations\\\": [\n    {\n      \\\"id\\\": \\\"obs-001\\\",\n      \\\"evidence\\\": [\n        \\\"existing-app-intake: LaunchRouter and onboarding precede auth and dashboard access.\\\",\n        \\\"competitor-flows: onboarding-first sequence appears to be a stable pattern.\\\"\n      ],\n      \\\"what_to_adapt\\\": \\\"Preserve launch ordering but expose a clear path for users who want to defer setup while still seeing value.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not force a strict first-run chain that blocks mission access without choice.\\\"\n    },\n    {\n      \\\"id\\\": \\\"obs-002\\\",\n      \\\"evidence\\\": [\n        \\\"existing-app-intake: Home, Runs, Profile tabs are present but profile/help and mission controls are grouped together.\\\",\n        \\\"competitor-flows: operational and settings actions should be better separated.\\\"\n      ],\n      \\\"what_to_adapt\\\": \\\"Separate operational mission actions from account/legal/support areas inside profile and home surfaces.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not keep critical wake actions adjacent to high-risk or legal actions.\\\"\n    },\n    {\n      \\\"id\\\": \\\"obs-003\\\",\n      \\\"evidence\\\": [\n        \\\"existing-app-intake: Wake flow includes mission progression and active state logic.\\\",\n        \\\"preflight and baseline outputs: no simulator capture exists in this environment.\\\"\n      ],\n      \\\"what_to_adapt\\\": \\\"Make active and completion states explicit before adding visual polish not validated by screenshots.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not hide wake transitions behind implicit state changes.\\\"\n    },\n    {\n      \\\"id\\\": \\\"obs-004\\\",\n      \\\"evidence\\\": [\n        \\\"pageflows-research: recommends progressive setup, single-action urgent state, and recovery paths.\\\"\n      ],\n      \\\"what_to_adapt\\\": \\\"Split setup into calm setup then urgent wake execution, then recovery with next-step continuity.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not overload early screens with strict mission controls before intent confirmation.\\\"\n    },\n    {\n      \\\"id\\\": \\\"obs-005\\\",\n      \\\"evidence\\\": [\n        \\\"mobbin-mcp-research: fallback indicates non-proprietary pattern extraction and trust-preserving recovery.\\\"\n      ],\n      \\\"what_to_adapt\\\": \\\"Use calm framing for reward/accountability screens and repair-first responses after misses