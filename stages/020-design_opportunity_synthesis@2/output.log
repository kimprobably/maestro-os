{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/bash -lc \"cat > .workflow/iphone-app-ux-studio/research/reference-pack.json <<'EOF'\n{\n  \\\"references\\\": [\n    {\n      \\\"id\\\": \\\"ref-competitor-001\\\",\n      \\\"title\\\": \\\"Deterministic onboarding-first launch\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"onboarding\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Intake and competitor artifact together show the launch route moves through onboarding before auth and shell access, creating a strict first-run sequence.\\\",\n      \\\"what_to_adapt\\\": \\\"Keep sequencing visible and guided but add a skip-safe calm path so users can proceed after first wake intent is known.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not lock users behind rigid pages before core value screens are reachable.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-002\\\",\n      \\\"title\\\": \\\"Tab-shell task workspace\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"home\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Current app structure uses Home, Runs, and Profile tabs; competitor notes emphasize clear navigation boundaries for task flows.\\\",\n      \\\"what_to_adapt\\\": \\\"Preserve the tab mental model but strengthen labels and defaults so users immediately find active mission paths.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not use ambiguous tab semantics that hide wake execution under generic actions.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-003\\\",\n      \\\"title\\\": \\\"Active mission priority\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Wake dashboard and active-task references include mission progression and completion states, with success and fail transitions already modeled in current screens.\\\",\n      \\\"what_to_adapt\\\": \\\"Prioritize one dominant action while active with immediate status feedback and next-step controls.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not clutter the active screen with non-essential navigation or settings access.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-competitor-004\\\",\n      \\\"title\\\": \\\"Profile operational/account separation\\\",\n      \\\"source\\\": \\\"competitor\\\",\n      \\\"source_type\\\": \\\"competitor_flow\\\",\n      \\\"category\\\": \\\"competitor_flow\\\",\n      \\\"screen_type\\\": \\\"profile_settings\\\",\n      \\\"source_url\\\": \\\".workflow/iphone-app-ux-studio/research/competitor-flows.md\\\",\n      \\\"evidence_summary\\\": \\\"Intake shows profile, help, legal, and destructive actions are co-located, which can overload users after wake operations.\\\",\n      \\\"what_to_adapt\\\": \\\"Separate mission operations from legal/account actions with calmer section hierarchy.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not place high-risk or account actions adjacent to core wake controls.\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-001\\\",\n      \\\"title\\\": \\\"Progressive wake setup path\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"create_edit\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback Page Flows notes model multi-step setup in calm sequence with task intent before strictness controls.\\\",\n      \\\"what_to_adapt\\\": \\\"Use staged task creation: choose intent, then configure optional strictness, then finalize mission details.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not show all setup controls in a single high-pressure screen.\\\",\n      \\\"provider\\\": \\\"pageflows\\\",\n      \\\"tags\\\": [\\\"pageflows\\\", \\\"calm_setup\\\", \\\"progressive_disclosure\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-002\\\",\n      \\\"title\\\": \\\"Single-action urgent wake execution\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"active_task\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback references recommend a single dominant interaction in mission-active phases and visible progress markers.\\\",\n      \\\"what_to_adapt\\\": \\\"Keep one primary wake CTA and clear progress text during active state.\\\",\n      \\\"what_not_to_copy\\\": \\\"Do not add parallel action trees that interrupt urgent completion.\\\",\n      \\\"provider\\\": \\\"page flows\\\",\n      \\\"tags\\\": [\\\"page flows\\\", \\\"urgent_wake\\\", \\\"single_action\\\"],\n      \\\"url\\\": \\\"https://pageflows.com/\\\"\n    },\n    {\n      \\\"id\\\": \\\"ref-pageflows-003\\\",\n      \\\"title\\\": \\\"Completion recovery without shame\\\",\n      \\\"source\\\": \\\"pageflows\\\",\n      \\\"source_type\\\": \\\"pattern_library\\\",\n      \\\"category\\\": \\\"pattern_library\\\",\n      \\\"screen_type\\\": \\\"completion\\\",\n      \\\"source_url\\\": \\\"https://pageflows.com/\\\",\n      \\\"evidence_summary\\\": \\\"Fallback notes describe conf