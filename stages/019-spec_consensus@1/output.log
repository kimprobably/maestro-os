tation-consensus.md\\\",\\n      \\\"stage\\\": \\\"code-review\\\",\\n      \\\"must_include\\\": [\\\"implementation-consensus.md\\\", \\\"VERDICT: APPROVED\\\", \\\"VERDICT: REJECTED\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/simplification.md\\\",\\n      \\\"stage\\\": \\\"simplify\\\",\\n      \\\"must_include\\\": [\\\"split Swift files\\\", \\\"400 lines\\\", \\\"do not remove quality gates\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/ai-ui-explorer.md\\\",\\n      \\\"stage\\\": \\\"qa\\\",\\n      \\\"must_include\\\": [\\\"tap every reachable\\\", \\\"reports/ios/appium-exploratory-report.json\\\", \\\"crashes\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/app-store-hardening.md\\\",\\n      \\\"stage\\\": \\\"release\\\",\\n      \\\"must_include\\\": [\\\"SwiftAI\\\", \\\"Boilerplate\\\", \\\"release strings audit: PASS\\\", \\\"Privacy\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/review-product-fidelity.md\\\",\\n      \\\"stage\\\": \\\"final-review\\\",\\n      \\\"must_include\\\": [\\\"spec.md\\\", \\\"research synthesis\\\", \\\"template-like\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/review-ios-architecture.md\\\",\\n      \\\"stage\\\": \\\"final-review\\\",\\n      \\\"must_include\\\": [\\\"architecture.md\\\", \\\"Swift 6\\\", \\\"CompositionRoot\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/review-security-privacy.md\\\",\\n      \\\"stage\\\": \\\"final-review\\\",\\n      \\\"must_include\\\": [\\\"Security\\\", \\\"Privacy\\\", \\\"hardcoded secrets\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/review-code-quality.md\\\",\\n      \\\"stage\\\": \\\"final-review\\\",\\n      \\\"must_include\\\": [\\\"SwiftLint\\\", \\\"SwiftFormat\\\", \\\"Qlty\\\"]\\n    },\\n    {\\n      \\\"path\\\": \\\"prompts/iphone-app-factory/review-release