{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"node <<'NODE'\nconst terms = [\n  'alarmy',\n  'challenges alarm clock',\n  'barcode alarm clock',\n  'sleep cycle alarm clock',\n  'nuj alarm clock',\n  'alarm clock puzzles'\n];\n\nasync function j(url){\n  const r=await fetch(url);\n  if(\"'!r.ok) throw new Error(`${r.status} ${url}`);\n  return r.json();\n}\n\nasync function search(term){\n  const url='\"'https://itunes.apple.com/search?entity=software&country=us&limit=10&term='+encodeURIComponent(term);\n  const data=await j(url);\n  return data.results||[];\n}\n\nasync function reviews(appId){\n  const url=\"'`https://itunes.apple.com/us/rss/customerreviews/id=${appId}/sortBy=mostRecent/json`;\n  const data=await j(url);\n  const entries = data.feed?.entry||[];\n  return entries.slice(1,16).map(e=>( {\n    author:e.author?.name?.label||'\"'',\n    title:e.title?.label||'',\n    content:e.content?.label||'',\n    rating:Number(e['im:rating']?.label||0),\n    version:e['im:version']?.label||'',\n    updated:e.updated?.label||''\n  }));\n}\n\n(async()=>{\n  const seen = new Map();\n  for (const term of terms){\n    const res=await search(term);\n    for(const app of res){\n      const id=app.trackId;\n      if(\"'!seen.has(id)) seen.set(id, {id, term, name:app.trackName, seller:app.sellerName, url:app.trackViewUrl, genre:app.primaryGenreName, rating:app.averageUserRating, ratingCount:app.userRatingCount, releaseNotes:app.releaseNotes||'\"'', description:app.description?.slice(0,220)||''});\n    }\n  }\n  const candidates=[...seen.values()]\n    .filter(a=>/alarm|sleep|wake|morning/i.test(a.name))\n    .sort((a,b)=>(b.ratingCount||0)-(a.ratingCount||0))\n    .slice(0,10);\n  for(const c of candidates){\n    try { c.reviews = await reviews(c.id);} catch(e){ c.reviewError=String(e.message);}    \n  }\n  console.log(JSON.stringify({generatedAt:new Date().toISOString(), candidates}, null, 2));\n})();\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
