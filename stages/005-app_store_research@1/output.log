 + '</span><span class=\"chip\">reviews +' + escapeHtml(app.reviewDelta4w) + '</span><span class=\"chip\">social +' + escapeHtml(app.socialDelta4w) + '</span><span class=\"chip\">mode ' + escapeHtml(app.dataMode || \"fixture\") + '</span></div>' +\nscripts/consumer-radar/generate-app.mjs:971:  \"for Apple RSS/iTunes and Apify actors. Set APIFY_TOKEN plus actor IDs in the\",\nscripts/consumer-radar/data-source-smoke.mjs:52:  apify_token_available: usableSecret(process.env.APIFY_TOKEN),\nscripts/consumer-radar/data-source-smoke.mjs:55:    appstore: process.env.APIFY_APPSTORE_ACTOR || \"crawlerbros/appstore-scraper\",\nscripts/consumer-radar/data-source-smoke.mjs:56:    tiktok: process.env.APIFY_TIKTOK_ACTOR || \"clockworks/tiktok-scraper\",\nscripts/consumer-radar/data-source-smoke.mjs:57:    instagram: process.env.APIFY_INSTAGRAM_ACTOR || \"apify/instagram-scraper\"\nscripts/consumer-radar/data-source-smoke.mjs:60:  apify_identity: null,\nscripts/consumer-radar/data-source-smoke.mjs:64:report.apple_review_rss = await fetchStatus(\"https://itunes.apple.com/us/rss/topfreeapplications/limit=25/genre=6007/json\");\nscripts/consumer-radar/data-source-smoke.mjs:66:if (report.apify_token_available) {\nscripts/consumer-radar/data-source-smoke.mjs:67:  report.apify_identity = await fetchStatus(\"https://api.apify.com/v2/users/me?token=\" + encodeURIComponent(process.env.APIFY_TOKEN));\nscripts/consumer-radar/data-source-smoke.mjs:69:  report.apify_identity = { ok: false, status: \"missing_or_unresolved_token\" };\nscripts/consumer-radar/data-source-smoke.mjs:74:  if (!report.apify_token_available) hardFailures.push(\"APIFY_TOKEN missing or unresolved\");\nscripts/consumer-radar/data-source-smoke.mjs:77:    if (!report.apple_review_rss?.ok) hardFailures.push(\"Apple RSS smoke failed\");\nscripts/consumer-radar/data-source-smoke.mjs:78:    if (!report.apify_identity?.ok) hardFailures.push(\"Apify identity smoke failed\");\nscripts/consumer-radar/data-source-smoke.mjs:80:    if 