e ID <input name=\"appStoreId\" placeholder=\"optional\" /></label>\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:604:    metric(app.rankDelta4w, \"rank 4w\") + metric(app.reviewDelta4w, \"reviews 4w\") + metric(app.socialDelta4w, \"social 4w\") +\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:632:function renderReviewSamples(app) {\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:633:  return '<div class=\"review-list\">' + (app.reviewSamples || []).map((review) =>\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:651:    \"<p>\" + escapeHtml(app.category + \" / rating \" + app.rating + \" / App Store ID \" + app.appStoreId) + \"</p>\" +\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:657:    '<section class=\"brief-section\"><h4>Visible Reviews</h4>' + renderReviewSamples(app) + \"</section>\" +\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:976:  assert.ok(first.reviewSamples.length >= 2);\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:990:  const app = await addCustomApp({ name: \"Test Focus App\", category: \"Productivity\", appStoreId: \"test-focus-app\" });\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:993:  assert.ok(app.reviewSamples.length >= 1);\nscripts/app-feedback/apply-consumer-radar-feedback.mjs:1001:  for (const marker of [\"refresh-mode\", \"add-app-form\", \"growth-hypothesis\", \"reviewSamples\", \"exampleContent\", \"categoryLeader\"]) {\nprompts/app-feedback/live-enrichment-plan-b.md:1:# Consumer Radar Live Enrichment Plan B: Product Surface First\nprompts/app-feedback/live-enrichment-plan-b.md:3:Create implementation plan B for live Consumer Radar enrichment.\nprompts/app-feedback/live-enrichment-plan-a.md:1:# Consumer Radar Live Enrichment Plan A: Source First\nprompts/app-feedback/live-enrichment-plan-a.md:3:Create implementation plan A for live Consumer Radar enrichment.\nprompts/app-feedback/live-enrichment-plan-a.md:9:- Apify App Store discovery path\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:41:const apify = readIfExists(resolve(appDir, \"src/sources/apify.js\"));\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:56:  has_apify_runner: apify.includes(\"runApifyActor\"),\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:57:  has_apple_review_adapter: apple.includes(\"fetchAppleReviews\"),\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:63:  has_visible_reviews: client.includes(\"renderReviewSamples\"),\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:74:    required_work: \"Add a live discovery/enrichment endpoint and UI control that can run with APIFY_TOKEN.\",\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:77:if (!capabilities.has_apify_runner || !capabilities.has_social_adapter) {\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:81:    finding: \"Live Apify source adapters are missing or not wired into product behavior.\",\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:82:    required_work: \"Wire App Store, TikTok, and Instagram actor execution into app enrichment.\",\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:111:    \"Real-mode live discovery must fail if APIFY_TOKEN is absent and allow_fixture_fallback=false.\",\nscripts/app-feedback/analyze-enhancement-capabilities.mjs:112:    \"Growth hypotheses must cite live social or App Store evidence when marked liveScraped=true.\",\nprompts/app-feedback/live-enrichment-implementation.md:1:# Consumer Radar Live Enrichment Implementation\nprompts/app-feedback/live-enrichment-implementation.md:7:- Wire Apify actor execution into live app discovery and social-content enrichment.\nevals/workflow-quality/datasets/enhancement-discovery-golden.jsonl:1:{\"id\":\"consumer-radar-live-data\",\"input\":\"Feedback says growth hypotheses are not credible without Apify and asks for more apps, visible reviews, and example content.\",\"expected_quality\":[\"capability audit detects fixture-only behavior\",\"spec requires live data gates\",\"workflow fails real mode without credentials\",\"reviews and social examples require provenance\"]}\nevals/iphone-app-factory/prompt-registry.json:9:      \"must_include\": [\"App Store\", \"reviews\", \"evidence quality\", \"do not invent\", \"never print environment variables\", \"environment dump commands\"]\nevals/iphone-app-factory/datasets/prompt-quality-golden.jsonl:2:{\"id\":\"boilerplate-first\",\"input\":\"Implementation prompts should bias agents to extend SwiftAIBoilerplatePro instead of rebuilding auth, payments, AI, storage, networking, localization, settings, or design system.\",\"expected_quality\":[\"boilerplate reuse\",\"module boundaries\",\"CompositionRoot\",\"no platform rewrite\",\"App Store 4.3 awareness\"]}\n","exit_code":0,"status":"completed"}}
