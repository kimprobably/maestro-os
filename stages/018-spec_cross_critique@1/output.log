plification\",\n        prompt=\"@../../prompts/iphone-app-factory/simplification.md\"\n    ]\n    quality_contract_gate [\n        label=\"Quality Harness Contract\",\n        shape=parallelogram,\n        goal_gate=true,\n        retry_target=\"simplification\",\n        script=\"node scripts/iphone-app-factory/quality-contract-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'\"\n    ]\n    macos_ci_gate [\n        label=\"macOS iOS CI Gate\",\n        shape=parallelogram,\n        goal_gate=true,\n        retry_target=\"implement_integration\",\n        timeout=\"3600s\",\n        script=\"node scripts/iphone-app-factory/ios-ci-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --mode '{{ inputs.ios_validation_mode|default('github') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'\"\n    ]\n    ai_ui_explorer [\n        label=\"AI UI Explorer\",\n        class=\"macos\",\n        goal_gate=true,\n        retry_target=\"implement_interface\",\n        prompt=\"@../../prompts/iphone-app-factory/ai-ui-explorer.md\"\n    ]\n    appium_gate [\n        label=\"Appium Exploratory Gate\",\n        shape=parallelogram,\n        goal_gate=true,\n        retry_target=\"ai_ui_explorer\",\n        script=\"node scripts/iphone-app-factory/appium-report-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'\"\n    ]\n    app_store_hardening [\n        label=\"App Store 4.3 Hardening\",\n        class=\"review\",\n        goal_gate=true,\n        retry_target=\"implement_interface\",\n        prompt=\"@../../prompts/iphone-app-factory/app-store-hardening.md\"\n    ]\n    app_store_gate [\n        label=\"App Store Hardening Gate\",\n        shape=parallelogram,\n        goal_gate=true,\n        retry_target=\"app_store_hardening\",\n        script=\"node scripts/iphone-app-factory/app-store-hardening-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'\"\n    ]\n\n    final_review_fanout [label=\"Final Review Fan-Out\", shape=component, join_policy=\"wait_all\", max_parallel=1]\n    product_fidelity_review [label=\"Product Fidelity\", class=\"review\", prompt=\"@../../prompts/iphone-app-factory/review-product-fidelity.md\"]\n    ios_architecture_review [label=\"iOS Architecture\", class=\"review\", prompt=\"@../../prompts/iphone-app-factory/review-ios-architecture.md\"]\n    security_privacy_review [label=\"Security Privacy\", class=\"security\", prompt=\"@../../prompts/iphone-app-factory/review-security-privacy.md\"]\n    code_quality_review [label=\"Code Quality\", class=\"review\", prompt=\"@../../prompts/iphone-app-factory/review-code-quality.md\"]\n    release_readiness_review [label=\"Release Readiness\", class=\"review\", prompt=\"@../../prompts/iphone-app-factory/review-release-readiness.md\"]\n    qa_review [label=\"QA Evidence\", class=\"review\", prompt=\"@../../prompts/iphone-app-factory/review-qa-evidence.md\"]\n    final_review_join [label=\"Final Review Join\", shape=tripleoctagon, join_policy=\"wait_all\"]\n    final_consensus [\n        label=\"Final Consensus\",\n        class=\"review\",\n        goal_gate=true,\n        retry_target=\"simplification\",\n        fidelity=\"full\",\n        prompt=\"@../../prompts/iphone-app-factory/final-consensus.md\"\n    ]\n    final_gate [\n        label=\"Final Verdict Gate\",\n","exit_code":0,"status":"completed"}}
