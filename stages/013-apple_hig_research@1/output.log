e\": \"Wake dashboard as active-task entry\",\n      \"source\": \"competitor\",\n      \"source_type\": \"competitor_flow\",\n      \"category\": \"competitor_flow\",\n      \"screen_type\": \"active_task\",\n      \"source_url\": \".workflow/iphone-app-ux-studio/research/existing-app-intake.md\",\n      \"evidence_summary\": \"Wake flow includes active task list/state progression, with completion and wake-check interactions.\",\n      \"what_to_adapt\": \"Prioritize explicit active-task controls and immediate progress indication once a mission starts.\",\n      \"what_not_to_copy\": \"Do not overload the active screen with secondary decision links during wake mode.\",\n      \"tags\": [\"competitor\", \"urgent_mode\", \"mission_progress\"]\n    },\n    {\n      \"id\": \"ref-competitor-04\",\n      \"title\": \"Profile and account utility cluster\",\n      \"source\": \"competitor\",\n      \"source_type\": \"competitor_flow\",\n      \"category\": \"competitor_flow\",\n      \"screen_type\": \"profile_settings\",\n      \"source_url\": \".workflow/iphone-app-ux-studio/research/existing-app-intake.md\",\n      \"evidence_summary\": \"Profile includes account/help/legal actions and destructive actions mixed into one section in current structure.\",\n      \"what_to_adapt\": \"Use account/support sectioning with calmer hierarchy and clearer action grouping.\",\n      \"what_not_to_copy\": \"Do not keep operational and high-risk actions at the same visual weight or proximity.\",\n      \"tags\": [\"competitor\", \"profile\", \"settings\"]\n    },\n    {\n      \"id\": \"ref-pageflows-01\",\n      \"title\": \"Setup flow with friction reduction\",\n      \"source\": \"pageflows\",\n      \"source_type\": \"page_flow_reference\",\n      \"category\": \"pattern_library\",\n      \"screen_type\": \"onboarding\",\n      \"source_url\": \"pageflows-style fallback reference set (no direct capture available)\",\n      \"evidence_summary\": \"Mobbin/PageFlows artifacts were n