digraph BuildIPhoneApp {
    graph [
        goal="Build a differentiated iPhone app from a researched app opportunity using SwiftAIBoilerplatePro",
        persona="iphone-app-factory",
        secret_policy="never print environment variables or credential values; credential checks must be presence-only true/false checks; do not run environment dump commands.",
        inputs="app_type,target_audience,app_name,bundle_id,app_dir,spec_kitty_feature,boilerplate_repo,max_competitors,use_mobbin,ios_validation_mode,allow_macos_deferred",
        outputs="research_pack,spec,architecture,swift_app,ios_quality_report,appium_report,release_handoff",
        default_max_retries=2,
        retry_target="spec_consensus",
        fallback_retry_target="architecture_consensus",
        model_stylesheet="
            *                  { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: low; }
            .research          { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .design            { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .spec              { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .architecture      { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .coding            { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .review            { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .verify            { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: medium; }
            .security          { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .simplify          { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            .macos             { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #spec_codex        { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #spec_claude       { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #spec_kimi         { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #spec_deepseek     { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #arch_codex        { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
            #arch_claude       { backend: cli; provider: openrouter; model: google/gemini-3.1-pro-preview; reasoning_effort: high; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    bootstrap [
        label="Bootstrap iPhone Factory",
        shape=parallelogram,
        goal_gate=true,
        retry_target="bootstrap",
        script="node scripts/iphone-app-factory/bootstrap.mjs --app-dir '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --app-name '{{ inputs.app_name|default('Generated iPhone App') }}' --bundle-id '{{ inputs.bundle_id|default('com.maestro.generatediphoneapp') }}' --boilerplate-repo '{{ inputs.boilerplate_repo|default('SwiftAIBoilerplatePro/SwiftAIBoilerplatePro-Distribution') }}'"
    ]
    run_input_gate [
        label="Run Input Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="run_input_gate",
        script="node scripts/iphone-app-factory/run-input-gate.mjs --app-type '{{ inputs.app_type|default('') }}' --target-audience '{{ inputs.target_audience|default('') }}' --app-name '{{ inputs.app_name|default('Generated iPhone App') }}' --bundle-id '{{ inputs.bundle_id|default('com.maestro.generatediphoneapp') }}' --app-dir '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --spec-kitty-feature '{{ inputs.spec_kitty_feature|default('iphone-app-factory') }}' --ios-validation-mode '{{ inputs.ios_validation_mode|default('github') }}' --allow-macos-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]

    prompt_quality_patch [
        label="Patch Prompt Quality Gaps v3",
        shape=parallelogram,
        goal_gate=true,
        retry_target="prompt_quality_patch",
        script="set -eu\nnode - <<'NODE'\nconst fs = require('fs');\nfunction appendAfter(path, anchor, insert) {\n  let text = fs.readFileSync(path, 'utf8');\n  if (text.includes(insert.trim().split('\\n')[0])) return false;\n  if (!text.includes(anchor)) throw new Error(`${path}: missing patch anchor`);\n  text = text.replace(anchor, `${anchor}\\n\\n${insert}`);\n  fs.writeFileSync(path, text);\n  return true;\n}\nfunction replaceOnce(path, oldText, newText) {\n  let text = fs.readFileSync(path, 'utf8');\n  if (text.includes(newText)) return false;\n  if (!text.includes(oldText)) throw new Error(`${path}: missing replace anchor`);\n  text = text.replace(oldText, newText);\n  fs.writeFileSync(path, text);\n  return true;\n}\nconst changed = [];\nif (appendAfter('prompts/iphone-app-factory/spec-consensus.md', 'The Definition of Done must be checklist-based and testable.', `The Definition of Done must include a \\`Run Recovery And Evidence\\` checklist with:\n\n- control-plane failure classification and recovery: if prompt materialization, networking, metadata push, or artifact collection fails after useful state exists, preserve artifacts, record branch/SHA/checkpoint, compact large context, and restart or fork from the pushed run branch; do not treat the failed run as cleanly complete.\n- hosted macOS CI fallback policy: when \\`allow_macos_deferred=false\\`, require GitHub Actions hosted macOS evidence with run id, commit SHA, successful conclusion, and artifact names; workflow-only CI declarations are not sufficient.\n- deferral handling: if \\`allow_macos_deferred=true\\`, list explicit deferred iOS/Appium evidence, accepted risk, compensating controls, and review deadline; when false, reject missing macOS/Appium evidence.\n- artifact preservation: final handoff must include app artifacts under \\`apps/*-iphone\\`, root GitHub workflows, \\`reports/ios\\`, metadata branch push status, and handoff manifest evidence.`)) changed.push('spec-consensus.md');\nif (appendAfter('prompts/iphone-app-factory/architecture-consensus.md', 'If any module is removed, the ADR must explain dependency order and App Store 4.3 consequences.', `The architecture must also define the recovery/evidence lane:\n\n- how generated app, \\`.workflow/iphone-app-factory\\`, \\`.github/workflows\\`, and \\`reports/ios\\` artifacts survive control-plane failures;\n- where GitHub Actions hosted macOS run id, commit SHA, successful conclusion, and artifact names are recorded when \\`allow_macos_deferred=false\\`;\n- how metadata branch push failures are classified and retried from the pushed run branch instead of being treated as successful completion;\n- how \\`allow_macos_deferred\\` changes Appium/XCUITest evidence requirements, including explicit accepted-risk notes only when deferral is true.`)) changed.push('architecture-consensus.md');\nif (appendAfter('prompts/iphone-app-factory/review-release-readiness.md', 'Reject if the app claims App Store readiness without macOS/Xcode evidence.', `Also reject when any of these are missing for \\`allow_macos_deferred=false\\`:\n\n- GitHub Actions hosted macOS run id;\n- commit SHA and branch;\n- successful workflow conclusion;\n- artifact names or links for xcodebuild/Appium/release evidence;\n- metadata branch push verification and handoff manifest;\n- explicit classification of any control-plane failure, with restart/fork instructions from the pushed run branch.\n\nWorkflow-only CI declarations, local-text claims, or fallback-only evidence are not enough.`)) changed.push('review-release-readiness.md');\nif (appendAfter('prompts/iphone-app-factory/review-qa-evidence.md', 'Reject if Appium did not tap reachable controls or if failures are unresolved.', `For \\`allow_macos_deferred=false\\`, reject if Appium/XCUITest or hosted macOS evidence is only described textually. Require GitHub Actions run id, commit SHA, successful conclusion, artifact names, and the concrete \\`reports/ios/appium-exploratory-report.json\\` or equivalent artifact. If deferral is true, the review must name the accepted risk, compensating controls, and review deadline.`)) changed.push('review-qa-evidence.md');\nif (appendAfter('prompts/iphone-app-factory/ai-ui-explorer.md', 'Do not mark the pass complete unless a real simulator/Appium run happened, unless the workflow explicitly allows macOS deferral.', `When \\`allow_macos_deferred=false\\`, the explorer/handoff must point to hosted macOS or simulator evidence, not workflow-only claims. Record the GitHub Actions run id, commit SHA, successful conclusion, artifact names, and any controls skipped. When deferral is allowed, write an explicit risk note and do not call the app TestFlight-ready.`)) changed.push('ai-ui-explorer.md');\nif (appendAfter('prompts/iphone-app-factory/final-consensus.md', '- If App Store 4.3 hardening did not pass, reject.', `- If the handoff lacks artifact preservation evidence, metadata branch push verification, or restart/fork notes for control-plane failures, reject.\n- If \\`allow_macos_deferred=false\\`, require GitHub Actions hosted macOS run id, commit SHA, successful conclusion, and artifact names for xcodebuild/Appium/release evidence; workflow-only claims are not enough.\n- If \\`allow_macos_deferred=true\\`, list accepted risk, compensating controls, review deadline, and deferred evidence explicitly; do not call the build release-ready.`)) changed.push('final-consensus.md');\n\nconst yamlPath = 'evals/iphone-app-factory/prompt-quality.yaml';\nlet yamlText = fs.readFileSync(yamlPath, 'utf8');\nconst beforeYaml = yamlText;\nyamlText = yamlText.replace(/openrouter:anthropic\\/claude-haiku-4-5/g, 'openrouter:anthropic/claude-sonnet-4');\nyamlText = yamlText.replace(/max_tokens: 1200/g, 'max_tokens: 2000');\nconst oldInstruction = '    Return valid JSON only, no markdown fences. It must match this shape:';\nconst newInstruction = '    Return exactly one minified JSON object and nothing else. Your first character must be `{` and your last character must be `}`. Do not include markdown fences, headings, prose, comments, or preambles. Include every required key exactly as shown, including literal keys `required_artifacts` and `risks`, even when arrays are empty. If you find gaps, put them in `critical_gaps`, `gaps`, or `risks` inside JSON; never switch to narrative.';\nyamlText = yamlText.replace(oldInstruction, newInstruction);\nconst oldParse = '          const parsed = JSON.parse(output);';\nconst newParse = '          const rawOutput = String(output || \"\").trim();\\n          const normalizedOutput = rawOutput.replace(/^```(?:json|javascript|js)?\\\\s*/i, \"\").replace(/```\\\\s*$/i, \"\").trim();\\n          const parsed = JSON.parse(normalizedOutput); // JSON.parse(output) after markdown-fence normalization';\nyamlText = yamlText.replace(oldParse, newParse);\nif (yamlText !== beforeYaml) {\n  fs.writeFileSync(yamlPath, yamlText);\n  changed.push('prompt-quality.yaml');\n}\n\nconst registryPath = 'evals/iphone-app-factory/prompt-registry.json';\nconst registry = JSON.parse(fs.readFileSync(registryPath, 'utf8'));\nconst markersByPath = {\n  'prompts/iphone-app-factory/spec-consensus.md': ['control-plane failure', 'hosted macOS CI', 'allow_macos_deferred', 'artifact preservation'],\n  'prompts/iphone-app-factory/architecture-consensus.md': ['metadata branch push', 'GitHub Actions hosted macOS', 'allow_macos_deferred'],\n  'prompts/iphone-app-factory/review-release-readiness.md': ['GitHub Actions hosted macOS run id', 'metadata branch push verification', 'control-plane failure'],\n  'prompts/iphone-app-factory/review-qa-evidence.md': ['allow_macos_deferred', 'GitHub Actions run id', 'reports/ios/appium-exploratory-report.json'],\n  'prompts/iphone-app-factory/ai-ui-explorer.md': ['allow_macos_deferred', 'GitHub Actions run id', 'artifact names'],\n  'prompts/iphone-app-factory/final-consensus.md': ['metadata branch push verification', 'control-plane failures', 'GitHub Actions hosted macOS run id']\n};\nlet registryChanged = false;\nfor (const entry of registry.prompts || []) {\n  const markers = markersByPath[entry.path];\n  if (!markers) continue;\n  entry.must_include = Array.isArray(entry.must_include) ? entry.must_include : [];\n  for (const marker of markers) {\n    if (!entry.must_include.includes(marker)) {\n      entry.must_include.push(marker);\n      registryChanged = true;\n    }\n  }\n}\nif (registryChanged) {\n  fs.writeFileSync(registryPath, JSON.stringify(registry, null, 2) + '\\n');\n  changed.push('prompt-registry.json');\n}\nfs.mkdirSync('.workflow/iphone-app-factory/evidence', { recursive: true });\nfs.writeFileSync('.workflow/iphone-app-factory/evidence/prompt-quality-hotfix.md', `# Prompt Quality Hotfix v3\\n\\nPatched prompt suite before prompt quality gate.\\n\\nFiles changed:\\n${changed.map((name) => `- ${name}`).join('\\n') || '- none; already patched'}\\n\\nReason: prior Joni Capture runs failed prompt_quality_gate because Promptfoo identified missing reproducibility coverage, then failed JSON parsing on fenced model output. This patch adds recovery/macOS/artifact requirements, increases completion budget, switches to a stronger OpenRouter model, and normalizes markdown-fenced JSON inside the assertion without accepting fallback-only risk.\\n`);\nconsole.log(JSON.stringify({ ok: true, changed }));\nNODE"
    ]


    prompt_quality_gate [
        label="Prompt Quality Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="prompt_quality_gate",
        script="node scripts/iphone-app-factory/promptfoo-prompt-quality.mjs --config evals/iphone-app-factory/prompt-quality.yaml --registry evals/iphone-app-factory/prompt-registry.json --out .workflow/iphone-app-factory/evals/prompt-quality.json --allow-fallback true --accepted-risk-promptfoo-failure false"
    ]

    research_fanout [label="Research Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    app_store_research [label="App Store Reviews", class="research", prompt="@../../prompts/iphone-app-factory/research-app-store.md"]
    reddit_research [label="Reddit Pain Mining", class="research", prompt="@../../prompts/iphone-app-factory/research-reddit.md"]
    competitor_research [label="Competitor Research", class="research", prompt="@../../prompts/iphone-app-factory/research-competitors.md"]
    design_pattern_research [label="Design Pattern Research", class="design", prompt="@../../prompts/iphone-app-factory/research-design-patterns.md"]
    research_join [label="Research Join", shape=tripleoctagon, join_policy="wait_all"]

    research_synthesis [
        label="Research Synthesis",
        class="research",
        goal_gate=true,
        retry_target="research_fanout",
        prompt="@../../prompts/iphone-app-factory/synthesize-research.md"
    ]
    research_evidence_gate [
        label="Research Evidence Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="research_fanout",
        script="node scripts/iphone-app-factory/research-evidence-gate.mjs"
    ]

    spec_fanout [label="Adversarial Spec Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    spec_codex [label="Gemini Spec", class="spec", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_claude [label="Claude Spec", class="spec", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_kimi [label="Kimi Spec", class="spec", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_deepseek [label="DeepSeek Spec", class="spec", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/spec-candidate.md"]
    spec_join [label="Spec Join", shape=tripleoctagon, join_policy="wait_all"]

    spec_cross_critique [
        label="Spec Cross-Critique",
        class="review",
        goal_gate=true,
        retry_target="spec_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/spec-cross-critique.md"
    ]
    spec_consensus [
        label="Spec Consensus",
        class="spec",
        goal_gate=true,
        retry_target="spec_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/spec-consensus.md"
    ]
    spec_red_team [
        label="Spec Red Team",
        class="review",
        goal_gate=true,
        retry_target="spec_consensus",
        prompt="@../../prompts/iphone-app-factory/spec-red-team.md"
    ]
    spec_quality_gate [
        label="Spec Quality Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="spec_consensus",
        script="node scripts/iphone-app-factory/spec-gate.mjs"
    ]
    spec_kitty_gate [
        label="Spec Kitty Mission",
        shape=parallelogram,
        goal_gate=true,
        retry_target="spec_consensus",
        script="FEATURE='{{ inputs.spec_kitty_feature|default('iphone-app-factory') }}'; if command -v spec-kitty >/dev/null 2>&1; then spec-kitty specify \"$FEATURE\" --mission-type software-dev --json > .workflow/iphone-app-factory/spec-kitty.json || spec-kitty verify-setup --json > .workflow/iphone-app-factory/spec-kitty.json; else echo 'spec-kitty is required for this workflow' >&2; exit 1; fi; cat .workflow/iphone-app-factory/spec-kitty.json"
    ]

    architecture_fanout [label="Architecture Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    arch_codex [label="Qwen Architecture", class="architecture", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/architecture-candidate.md"]
    arch_claude [label="Claude Architecture", class="architecture", fidelity="truncate", prompt="@../../prompts/iphone-app-factory/architecture-candidate.md"]
    architecture_join [label="Architecture Join", shape=tripleoctagon, join_policy="wait_all"]
    architecture_consensus [
        label="Architecture And ADR",
        class="architecture",
        goal_gate=true,
        retry_target="architecture_fanout",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/architecture-consensus.md"
    ]
    architecture_gate [
        label="Architecture Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="architecture_consensus",
        script="test -s .workflow/iphone-app-factory/architecture.md; test -s .workflow/iphone-app-factory/adr.md; grep -Eq 'SwiftAIBoilerplatePro|boilerplate|Packages/|DesignSystem|CompositionRoot' .workflow/iphone-app-factory/architecture.md"
    ]

    boilerplate_setup [
        label="Clone And Rebrand Boilerplate",
        class="coding",
        goal_gate=true,
        retry_target="boilerplate_setup",
        prompt="@../../prompts/iphone-app-factory/boilerplate-setup.md"
    ]
    boilerplate_gate [
        label="Boilerplate Contract Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="boilerplate_setup",
        script="node scripts/iphone-app-factory/boilerplate-contract-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]

    implement_foundation [label="Implement Foundation", class="coding", goal_gate=true, retry_target="implement_foundation", prompt="@../../prompts/iphone-app-factory/implement-foundation.md"]
    verify_foundation [label="Verify Foundation", class="verify", goal_gate=true, retry_target="implement_foundation", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_foundation [label="Foundation Gate", shape=parallelogram, goal_gate=true, retry_target="implement_foundation", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs foundation '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_core [label="Implement Core", class="coding", goal_gate=true, retry_target="implement_core", prompt="@../../prompts/iphone-app-factory/implement-core.md"]
    verify_core [label="Verify Core", class="verify", goal_gate=true, retry_target="implement_core", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_core [label="Core Gate", shape=parallelogram, goal_gate=true, retry_target="implement_core", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs core '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_interface [label="Implement Interface", class="coding", goal_gate=true, retry_target="implement_interface", prompt="@../../prompts/iphone-app-factory/implement-interface.md"]
    verify_interface [label="Verify Interface", class="verify", goal_gate=true, retry_target="implement_interface", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_interface [label="Interface Gate", shape=parallelogram, goal_gate=true, retry_target="implement_interface", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs interface '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implement_integration [label="Implement Integration", class="coding", goal_gate=true, retry_target="implement_integration", prompt="@../../prompts/iphone-app-factory/implement-integration.md"]
    verify_integration [label="Verify Integration", class="verify", goal_gate=true, retry_target="implement_integration", prompt="@../../prompts/iphone-app-factory/verify-phase.md"]
    gate_integration [label="Integration Gate", shape=parallelogram, goal_gate=true, retry_target="implement_integration", script="node scripts/iphone-app-factory/phase-evidence-gate.mjs integration '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"]

    implementation_review_fanout [label="Implementation Review Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    implementation_correctness_review [label="Implementation Correctness", class="review", prompt="@../../prompts/iphone-app-factory/review-implementation-correctness.md"]
    implementation_test_review [label="Implementation Tests", class="review", prompt="@../../prompts/iphone-app-factory/review-implementation-tests.md"]
    implementation_security_review [label="Implementation Security", class="security", prompt="@../../prompts/iphone-app-factory/review-implementation-security.md"]
    implementation_boilerplate_review [label="Implementation Boilerplate", class="review", prompt="@../../prompts/iphone-app-factory/review-implementation-boilerplate.md"]
    implementation_review_join [label="Implementation Review Join", shape=tripleoctagon, join_policy="wait_all"]
    implementation_review_fan_in_gate [
        label="Implementation Review Fan-In Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implementation_review_fanout",
        script="node scripts/iphone-app-factory/review-fan-in-gate.mjs --mode implementation --reviews-dir .workflow/iphone-app-factory/reviews"
    ]
    implementation_review_consensus [
        label="Implementation Review Consensus",
        class="review",
        goal_gate=true,
        retry_target="implement_integration",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/review-implementation-consensus.md"
    ]
    implementation_review_gate [
        label="Implementation Review Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implement_integration",
        script="./bin/maestro verify text-gate .workflow/iphone-app-factory/reviews/implementation-consensus.md --pass 'VERDICT:\\s*APPROVED' --fail 'VERDICT:\\s*REJECTED|\\bREJECTED\\b'"
    ]
    prompt_context_budget_gate [
        label="Prompt Context Budget Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implementation_review_consensus",
        script="node scripts/iphone-app-factory/prompt-context-budget-gate.mjs --root .workflow/iphone-app-factory"
    ]

    simplification [
        label="Code Simplification",
        class="simplify",
        goal_gate=true,
        retry_target="simplification",
        prompt="@../../prompts/iphone-app-factory/simplification.md"
    ]
    quality_contract_gate [
        label="Quality Harness Contract",
        shape=parallelogram,
        goal_gate=true,
        retry_target="simplification",
        script="node scripts/iphone-app-factory/quality-contract-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    macos_ci_gate [
        label="macOS iOS CI Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="implement_integration",
        timeout="3600s",
        script="node scripts/iphone-app-factory/ios-ci-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --mode '{{ inputs.ios_validation_mode|default('github') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]
    ai_ui_explorer [
        label="AI UI Explorer",
        class="macos",
        goal_gate=true,
        retry_target="implement_interface",
        prompt="@../../prompts/iphone-app-factory/ai-ui-explorer.md"
    ]
    appium_gate [
        label="Appium Exploratory Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="ai_ui_explorer",
        script="node scripts/iphone-app-factory/appium-report-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}' --allow-deferred '{{ inputs.allow_macos_deferred|default('false') }}'"
    ]
    app_store_hardening [
        label="App Store 4.3 Hardening",
        class="review",
        goal_gate=true,
        retry_target="implement_interface",
        prompt="@../../prompts/iphone-app-factory/app-store-hardening.md"
    ]
    app_store_gate [
        label="App Store Hardening Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="app_store_hardening",
        script="node scripts/iphone-app-factory/app-store-hardening-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]

    final_review_fanout [label="Final Review Fan-Out", shape=component, join_policy="wait_all", max_parallel=1]
    product_fidelity_review [label="Product Fidelity", class="review", prompt="@../../prompts/iphone-app-factory/review-product-fidelity.md"]
    ios_architecture_review [label="iOS Architecture", class="review", prompt="@../../prompts/iphone-app-factory/review-ios-architecture.md"]
    security_privacy_review [label="Security Privacy", class="security", prompt="@../../prompts/iphone-app-factory/review-security-privacy.md"]
    code_quality_review [label="Code Quality", class="review", prompt="@../../prompts/iphone-app-factory/review-code-quality.md"]
    release_readiness_review [label="Release Readiness", class="review", prompt="@../../prompts/iphone-app-factory/review-release-readiness.md"]
    qa_review [label="QA Evidence", class="review", prompt="@../../prompts/iphone-app-factory/review-qa-evidence.md"]
    final_review_join [label="Final Review Join", shape=tripleoctagon, join_policy="wait_all"]
    final_review_fan_in_gate [
        label="Final Review Fan-In Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_review_fanout",
        script="node scripts/iphone-app-factory/review-fan-in-gate.mjs --mode final --reviews-dir .workflow/iphone-app-factory/reviews"
    ]
    final_prompt_context_budget_gate [
        label="Final Prompt Context Budget Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_review_fanout",
        script="node scripts/iphone-app-factory/prompt-context-budget-gate.mjs --root .workflow/iphone-app-factory"
    ]
    final_consensus [
        label="Final Consensus",
        class="review",
        goal_gate=true,
        retry_target="simplification",
        fidelity="full",
        prompt="@../../prompts/iphone-app-factory/final-consensus.md"
    ]
    final_gate [
        label="Final Verdict Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="simplification",
        script="./bin/maestro verify text-gate .workflow/iphone-app-factory/final-consensus.md --pass 'VERDICT:\\s*APPROVED' --fail 'VERDICT:\\s*REJECTED|\\bREJECTED\\b'"
    ]
    publish_handoff [
        label="Publish Handoff",
        shape=parallelogram,
        goal_gate=true,
        retry_target="final_consensus",
        script="node scripts/iphone-app-factory/publish-handoff.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    artifact_metadata_gate [
        label="Artifact Metadata Gate",
        shape=parallelogram,
        goal_gate=true,
        retry_target="publish_handoff",
        script="node scripts/iphone-app-factory/artifact-metadata-gate.mjs '{{ inputs.app_dir|default('apps/generated-iphone-app') }}'"
    ]
    memory_summary [
        label="Memory Summary",
        shape=parallelogram,
        script="printf '{\"kind\":\"iphone_app_factory.completed\",\"payload\":{\"app_dir\":\"{{ inputs.app_dir|default('apps/generated-iphone-app') }}\",\"app_name\":\"{{ inputs.app_name|default('Generated iPhone App') }}\"}}' | ./bin/maestro memory append 'team/iphone-app-factory/builds' >/dev/null; echo memory-updated"
    ]

    start -> run_input_gate
    run_input_gate -> bootstrap [condition="outcome=succeeded"]
    run_input_gate -> run_input_gate [label="Fix Inputs", loop_restart=true]
    bootstrap -> prompt_quality_patch [condition="outcome=succeeded"]
    prompt_quality_patch -> prompt_quality_gate [condition="outcome=succeeded"]
    prompt_quality_patch -> prompt_quality_patch [label="Retry", loop_restart=true]
    bootstrap -> bootstrap [label="Retry", loop_restart=true]
    prompt_quality_gate -> research_fanout [condition="outcome=succeeded"]
    prompt_quality_gate -> prompt_quality_gate [label="Retry", loop_restart=true]
    research_fanout -> app_store_research
    research_fanout -> reddit_research
    research_fanout -> competitor_research
    research_fanout -> design_pattern_research
    app_store_research -> research_join
    reddit_research -> research_join
    competitor_research -> research_join
    design_pattern_research -> research_join
    research_join -> research_synthesis
    research_synthesis -> research_evidence_gate [condition="outcome=succeeded"]
    research_synthesis -> research_fanout [label="Retry"]
    research_evidence_gate -> spec_fanout [condition="outcome=succeeded"]
    research_evidence_gate -> research_fanout [label="Retry"]

    spec_fanout -> spec_codex
    spec_fanout -> spec_claude
    spec_fanout -> spec_kimi
    spec_fanout -> spec_deepseek
    spec_codex -> spec_join
    spec_claude -> spec_join
    spec_kimi -> spec_join
    spec_deepseek -> spec_join
    spec_join -> spec_cross_critique
    spec_cross_critique -> spec_consensus [condition="outcome=succeeded"]
    spec_cross_critique -> spec_fanout [label="Retry"]
    spec_consensus -> spec_red_team [condition="outcome=succeeded"]
    spec_consensus -> spec_fanout [label="Retry"]
    spec_red_team -> spec_quality_gate [condition="outcome=succeeded"]
    spec_red_team -> spec_consensus [label="Fix"]
    spec_quality_gate -> spec_kitty_gate [condition="outcome=succeeded"]
    spec_quality_gate -> spec_consensus [label="Fix"]
    spec_kitty_gate -> architecture_fanout [condition="outcome=succeeded"]
    spec_kitty_gate -> spec_consensus [label="Fix"]

    architecture_fanout -> arch_codex
    architecture_fanout -> arch_claude
    arch_codex -> architecture_join
    arch_claude -> architecture_join
    architecture_join -> architecture_consensus
    architecture_consensus -> architecture_gate [condition="outcome=succeeded"]
    architecture_consensus -> architecture_fanout [label="Retry"]
    architecture_gate -> boilerplate_setup [condition="outcome=succeeded"]
    architecture_gate -> architecture_consensus [label="Fix"]

    boilerplate_setup -> boilerplate_gate [condition="outcome=succeeded"]
    boilerplate_setup -> boilerplate_setup [label="Retry", loop_restart=true]
    boilerplate_gate -> implement_foundation [condition="outcome=succeeded"]
    boilerplate_gate -> boilerplate_setup [label="Fix"]

    implement_foundation -> verify_foundation [condition="outcome=succeeded"]
    implement_foundation -> implement_foundation [label="Retry", loop_restart=true]
    verify_foundation -> gate_foundation [condition="outcome=succeeded"]
    verify_foundation -> implement_foundation [label="Fix"]
    gate_foundation -> implement_core [condition="outcome=succeeded"]
    gate_foundation -> implement_foundation [label="Fix"]

    implement_core -> verify_core [condition="outcome=succeeded"]
    implement_core -> implement_core [label="Retry", loop_restart=true]
    verify_core -> gate_core [condition="outcome=succeeded"]
    verify_core -> implement_core [label="Fix"]
    gate_core -> implement_interface [condition="outcome=succeeded"]
    gate_core -> implement_core [label="Fix"]

    implement_interface -> verify_interface [condition="outcome=succeeded"]
    implement_interface -> implement_interface [label="Retry", loop_restart=true]
    verify_interface -> gate_interface [condition="outcome=succeeded"]
    verify_interface -> implement_interface [label="Fix"]
    gate_interface -> implement_integration [condition="outcome=succeeded"]
    gate_interface -> implement_interface [label="Fix"]

    implement_integration -> verify_integration [condition="outcome=succeeded"]
    implement_integration -> implement_integration [label="Retry", loop_restart=true]
    verify_integration -> gate_integration [condition="outcome=succeeded"]
    verify_integration -> implement_integration [label="Fix"]
    gate_integration -> implementation_review_fanout [condition="outcome=succeeded"]
    gate_integration -> implement_integration [label="Fix"]

    implementation_review_fanout -> implementation_correctness_review
    implementation_review_fanout -> implementation_test_review
    implementation_review_fanout -> implementation_security_review
    implementation_review_fanout -> implementation_boilerplate_review
    implementation_correctness_review -> implementation_review_join
    implementation_test_review -> implementation_review_join
    implementation_security_review -> implementation_review_join
    implementation_boilerplate_review -> implementation_review_join
    implementation_review_join -> implementation_review_fan_in_gate
    implementation_review_fan_in_gate -> implementation_review_consensus [condition="outcome=succeeded"]
    implementation_review_fan_in_gate -> implement_integration [label="Fix"]
    implementation_review_consensus -> implementation_review_gate [condition="outcome=succeeded"]
    implementation_review_consensus -> implement_integration [label="Fix"]
    implementation_review_gate -> prompt_context_budget_gate [condition="outcome=succeeded"]
    implementation_review_gate -> implement_integration [label="Fix"]
    prompt_context_budget_gate -> simplification [condition="outcome=succeeded"]
    prompt_context_budget_gate -> implementation_review_consensus [label="Compact"]

    simplification -> quality_contract_gate [condition="outcome=succeeded"]
    simplification -> simplification [label="Retry", loop_restart=true]
    quality_contract_gate -> macos_ci_gate [condition="outcome=succeeded"]
    quality_contract_gate -> simplification [label="Fix"]
    macos_ci_gate -> ai_ui_explorer [condition="outcome=succeeded"]
    macos_ci_gate -> implement_integration [label="Fix"]
    ai_ui_explorer -> appium_gate [condition="outcome=succeeded"]
    ai_ui_explorer -> implement_interface [label="Fix"]
    appium_gate -> app_store_hardening [condition="outcome=succeeded"]
    appium_gate -> ai_ui_explorer [label="Fix"]
    app_store_hardening -> app_store_gate [condition="outcome=succeeded"]
    app_store_hardening -> implement_interface [label="Fix"]
    app_store_gate -> final_review_fanout [condition="outcome=succeeded"]
    app_store_gate -> app_store_hardening [label="Fix"]

    final_review_fanout -> product_fidelity_review
    final_review_fanout -> ios_architecture_review
    final_review_fanout -> security_privacy_review
    final_review_fanout -> code_quality_review
    final_review_fanout -> release_readiness_review
    final_review_fanout -> qa_review
    product_fidelity_review -> final_review_join
    ios_architecture_review -> final_review_join
    security_privacy_review -> final_review_join
    code_quality_review -> final_review_join
    release_readiness_review -> final_review_join
    qa_review -> final_review_join
    final_review_join -> final_review_fan_in_gate
    final_review_fan_in_gate -> final_prompt_context_budget_gate [condition="outcome=succeeded"]
    final_review_fan_in_gate -> simplification [label="Fix"]
    final_prompt_context_budget_gate -> final_consensus [condition="outcome=succeeded"]
    final_prompt_context_budget_gate -> final_review_fanout [label="Compact"]
    final_consensus -> final_gate [condition="outcome=succeeded"]
    final_consensus -> simplification [label="Fix"]
    final_gate -> publish_handoff [condition="outcome=succeeded"]
    final_gate -> simplification [label="Fix"]
    publish_handoff -> artifact_metadata_gate [condition="outcome=succeeded"]
    publish_handoff -> final_consensus [label="Fix"]
    artifact_metadata_gate -> memory_summary [condition="outcome=succeeded"]
    artifact_metadata_gate -> publish_handoff [label="Fix"]
    memory_summary -> exit [condition="outcome=succeeded"]
    memory_summary -> publish_handoff [label="Fix"]
}
