# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode
DerivedData/
build/
*.xccheckout
*.xcscmblueprint
*.xcuserstate
*.xcuserdatad/
*.moved-aside
*.ipa
*.dSYM.zip
*.dSYM
xcuserdata/

# Swift / SwiftPM
.swiftpm/
.build/
# Note: Packages/ contains our source code modules, not SPM dependencies
# SPM dependencies are in .build/ which is already ignored
# Keep the dependency lockfile
!Package.resolved

# Fastlane (if you add later)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# Config / Secrets
Config/Secrets.xcconfig
.env
.env.*

# Config / Secrets - Configuration.swift is committed with placeholders for clone-and-run
# Run 'bash scripts/update-config.sh' after filling in Secrets.xcconfig to update it with real values

# Backend proxies (choose what you use)
BackendProxy/**/node_modules/
BackendProxy/**/.wrangler/
BackendProxy/**/.venv/
BackendProxy/**/__pycache__/
BackendProxy/**/.python-version

# Editor cruft
*.orig
*.swp
.idea/
.vscode/

# Private release workflow docs — author-only handoff material for
# landing-page / docs / blog updates + internal-audit agent prompts.
# Not for end users / buyers of the boilerplate.
docs/release/

