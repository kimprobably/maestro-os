// Copy this file to Config/Secrets.xcconfig and fill these values.
// Never commit Config/Secrets.xcconfig with real credentials.
// See supabase/DEPLOYMENT_GUIDE.md for setup instructions

// Supabase Configuration
// Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL = https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY = PLACEHOLDER_SUPABASE_ANON_KEY

// Google Sign In (Optional)
// Get from: https://console.cloud.google.com → APIs & Services → Credentials
// Create iOS OAuth Client ID, then paste the client ID here
// GOOGLE_CLIENT_ID = YOUR_IOS_CLIENT_ID.apps.googleusercontent.com

// RevenueCat Configuration  
// Get from: https://app.revenuecat.com → Project Settings → API Keys
REVENUECAT_API_KEY = PLACEHOLDER_REVENUECAT_PUBLIC_KEY
RC_ENTITLEMENT_ID = pro

// AI Proxy Configuration (Supabase Edge Function)
// After deploying the Edge Function, use: https://YOUR-PROJECT-REF.supabase.co/functions/v1
PROXY_BASE_URL = https://YOUR-PROJECT-REF.supabase.co/functions/v1
PROXY_PATH = /ai

// OneSignal Push Notifications (Optional)
// Get from: https://onesignal.com → Settings → Keys & IDs
// Leave commented out if you don't want push notifications
// See docs/integrations/OneSignal.md for setup guide
ONESIGNAL_APP_ID = PLACEHOLDER_ONESIGNAL_APP_ID
