# Copy to deploy/fabro-server/env.server on the target server.
# Never commit env.server.

# Image selection:
# Use the official image for baseline Fabro, or point this at the Fabro fork
# image once the fork is published to GHCR.
FABRO_IMAGE=ghcr.io/fabro-sh/fabro:nightly

# Public URL and Caddy site address.
FABRO_SITE_ADDRESS=fabro.example.com
FABRO_WEB_URL=https://fabro.example.com

# Server auth. Generate with:
#   openssl rand -hex 32
#   printf 'fabro_dev_%s\n' "$(openssl rand -hex 32)"
SESSION_SECRET=
FABRO_DEV_TOKEN=

# GitHub native token integration. Use a fine-grained token scoped to the repo.
GITHUB_TOKEN=

# Slack Socket Mode integration.
FABRO_SLACK_BOT_TOKEN=
FABRO_SLACK_APP_TOKEN=
FABRO_SLACK_CHANNEL_ID=

# LLM providers.
OPENROUTER_API_KEY=

# Daytona for sandbox-backed workflow execution.
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_API_KEY=

# Linear API for workflow-created issues and project sync.
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql

# Optional: keep logs terse unless debugging.
FABRO_LOG=info
