# Local-only secrets for Maestro OS.
# Copy to .env.local and fill by hand. Never commit .env.local.

# Neon
DATABASE_URL=

# Slack app for Fabro Socket Mode
FABRO_SLACK_BOT_TOKEN=
FABRO_SLACK_APP_TOKEN=
FABRO_SLACK_CHANNEL_ID=

# Slack signing secret is not used by Fabro Socket Mode, but may be useful for
# future webhook-based Maestro CLI commands.
SLACK_SIGNING_SECRET=

# LLM providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_CREDENTIALS_JSON_BASE64=
CODEX_AUTH_JSON_BASE64=

# Daytona
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_API_KEY=

# Linear
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql

# Fabro local server auth
SESSION_SECRET=
FABRO_DEV_TOKEN=

# Fabro cloud server smoke tests
FABRO_REMOTE_URL=
FABRO_REMOTE_DEV_TOKEN=
